    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n\t<head>\n\t\t<meta charset=\"UTF-8\">\n\t\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t\t<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\t\t<style>\n\t\t\t* { box-sizing: border-box; margin: 0; padding: 0; }\n\n\t\t\t:root {\n\t\t\t\t--bg-card:    #222244;\n\t\t\t\t--bg-hover:   #2a2a50;\n\t\t\t\t--bg-surface: #16162b;\n\t\t\t\t--text-1:     #f0f0f5;\n\t\t\t\t--text-2:     #a0a0bb;\n\t\t\t\t--text-3:     #6e6e88;\n\t\t\t\t--green:      #58cc02;\n\t\t\t\t--green-bg:   rgba(88,204,2,0.12);\n\t\t\t\t--amber:      #ff9600;\n\t\t\t\t--amber-bg:   rgba(255,150,0,0.12);\n\t\t\t\t--red:        #ff4b4b;\n\t\t\t\t--red-bg:     rgba(255,75,75,0.12);\n\t\t\t\t--blue:       #1cb0f6;\n\t\t\t\t--blue-bg:    rgba(28,176,246,0.12);\n\t\t\t\t--border:     rgba(255,255,255,0.08);\n\t\t\t\t--radius:     14px;\n\t\t\t\t--font:       'Nunito', system-ui, sans-serif;\n\t\t\t}\n\n\t\t\tbody {\n\t\t\t\tbackground: transparent;\n\t\t\t\tfont-family: var(--font);\n\t\t\t\tcolor: var(--text-1);\n\t\t\t\tpadding: 4px;\n\t\t\t}\n\n\t\t\t.cards {\n\t\t\t\tdisplay: grid;\n\t\t\t\tgrid-template-columns: repeat(5, 1fr);\n\t\t\t\tgap: 10px;\n\t\t\t}\n\n\t\t\t.card {\n\t\t\t\tbackground: var(--bg-card);\n\t\t\t\tborder: 1px solid var(--border);\n\t\t\t\tborder-radius: var(--radius);\n\t\t\t\tpadding: 16px;\n\t\t\t\tcursor: default;\n\t\t\t\ttransition: border-color .2s, background .2s;\n\t\t\t\tdisplay: flex;\n\t\t\t\tflex-direction: column;\n\t\t\t\tgap: 10px;\n\t\t\t}\n\t\t\t.card:hover { background: var(--bg-hover); border-color: rgba(255,255,255,0.18); }\n\n\t\t\t.card-label {\n\t\t\t\tfont-size: 11px;\n\t\t\t\tfont-weight: 700;\n\t\t\t\tletter-spacing: .06em;\n\t\t\t\ttext-transform: uppercase;\n\t\t\t\tcolor: var(--text-3);\n\t\t\t}\n\n\t\t\t.card-main {\n\t\t\t\tdisplay: flex;\n\t\t\t\talign-items: center;\n\t\t\t\tjustify-content: space-between;\n\t\t\t\tgap: 8px;\n\t\t\t}\n\n\t\t\t.card-value {\n\t\t\t\tfont-size: 28px;\n\t\t\t\tfont-weight: 900;\n\t\t\t\tline-height: 1;\n\t\t\t\tcolor: var(--text-1);\n\t\t\t}\n\n\t\t\t.badge {\n\t\t\t\tfont-size: 11px;\n\t\t\t\tfont-weight: 800;\n\t\t\t\tpadding: 3px 9px;\n\t\t\t\tborder-radius: 20px;\n\t\t\t\twhite-space: nowrap;\n\t\t\t\tflex-shrink: 0;\n\t\t\t}\n\t\t\t.badge.green  { background: var(--green-bg);  color: var(--green);  }\n\t\t\t.badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n\t\t\t.badge.red    { background: var(--red-bg);    color: var(--red);    }\n\t\t\t.badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n\t\t\t.badge.neutral{ background: rgba(255,255,255,0.06); color: var(--text-3); }\n\n\t\t\t.divider {\n\t\t\t\theight: 1px;\n\t\t\t\tbackground: var(--border);\n\t\t\t}\n\n\t\t\t.sub-metrics { display: flex; flex-direction: column; gap: 6px; }\n\n\t\t\t.sub-row {\n\t\t\t\tdisplay: flex;\n\t\t\t\tjustify-content: space-between;\n\t\t\t\talign-items: center;\n\t\t\t\tfont-size: 12px;\n\t\t\t}\n\t\t\t.sub-label { color: var(--text-3); }\n\t\t\t.sub-value { color: var(--text-2); font-weight: 700; }\n\t\t\t.sub-value.green  { color: var(--green); }\n\t\t\t.sub-value.amber  { color: var(--amber); }\n\t\t\t.sub-value.red    { color: var(--red);   }\n\n\t\t\t/* Progress bar */\n\t\t\t.progress-wrap { display: flex; flex-direction: column; gap: 4px; }\n\t\t\t.progress-labels {\n\t\t\t\tdisplay: flex;\n\t\t\t\tjustify-content: space-between;\n\t\t\t\tfont-size: 10px;\n\t\t\t\tcolor: var(--text-3);\n\t\t\t}\n\t\t\t.progress-track {\n\t\t\t\theight: 6px;\n\t\t\t\tbackground: rgba(255,255,255,0.08);\n\t\t\t\tborder-radius: 99px;\n\t\t\t\toverflow: hidden;\n\t\t\t\tposition: relative;\n\t\t\t}\n\t\t\t.progress-fill {\n\t\t\t\theight: 100%;\n\t\t\t\tborder-radius: 99px;\n\t\t\t\ttransition: width .4s ease;\n\t\t\t}\n\t\t\t.progress-fill.green { background: var(--green); }\n\t\t\t.progress-fill.amber { background: var(--amber); }\n\t\t\t.progress-fill.red   { background: var(--red);   }\n\t\t\t.progress-fill.blue  { background: var(--blue);  }\n\n\t\t\t/* Funnel bars */\n\t\t\t.funnel { display: flex; flex-direction: column; gap: 4px; }\n\t\t\t.funnel-row { display: flex; align-items: center; gap: 6px; font-size: 11px; }\n\t\t\t.funnel-label { color: var(--text-3); width: 64px; flex-shrink: 0; }\n\t\t\t.funnel-track { flex: 1; height: 5px; background: rgba(255,255,255,0.08); border-radius: 99px; overflow: hidden; }\n\t\t\t.funnel-fill  { height: 100%; border-radius: 99px; background: var(--blue); }\n\t\t\t.funnel-val   { color: var(--text-2); font-weight: 700; width: 36px; text-align: right; flex-shrink: 0; }\n\n\t\t\t/* Stale buckets */\n\t\t\t.buckets { display: flex; gap: 6px; }\n\t\t\t.bucket  { flex: 1; background: rgba(255,255,255,0.05); border-radius: 8px; padding: 6px 4px; text-align: center; }\n\t\t\t.bucket-val   { font-size: 15px; font-weight: 800; }\n\t\t\t.bucket-label { font-size: 10px; color: var(--text-3); margin-top: 2px; }\n\t\t\t.bucket.b1 .bucket-val { color: var(--amber); }\n\t\t\t.bucket.b2 .bucket-val { color: var(--red);   }\n\t\t\t.bucket.b3 .bucket-val { color: #cc3c3c;      }\n\n\t\t\t.empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 20px; }\n\t\t</style>\n\t</head>\n\t<body>\n\n\t\t<div class=\"cards\" id=\"cards\">\n\t\t\t<div class=\"empty\">Lade Daten…</div>\n\t\t</div>\n\n\t\t<script>\n\t\t\tfunction fmt(n) {\n\t\t\t\tif (!n || n === 0) return '€\\u00a00';\n\t\t\t\tconst abs = Math.round(Math.abs(n));\n\t\t\t\tif (abs >= 1000000) return '€\\u00a0' + (abs / 1000000).toFixed(1).replace('.', ',') + ' Mio.';\n\t\t\t\tif (abs >= 1000)    return '€\\u00a0' + Math.round(abs / 1000) + 'k';\n\t\t\t\treturn '€\\u00a0' + abs.toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n\t\t\t}\n\t\t\tfunction fmtN(n) {\n\t\t\t\treturn (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n\t\t\t}\n\t\t\tfunction pct(n) { return (n || 0) + '\\u202f%'; }\n\t\t\tfunction clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n\t\t\tfunction statusLabel(s) {\n\t\t\t\treturn { green: 'Gesund', amber: 'Warnung', red: 'Kritisch' }[s] || '—';\n\t\t\t}\n\n\t\t\tfunction render(model) {\n\t\t\t\tconst d = model || {};\n\t\t\t\tconst b = d.bookings  || {};\n\t\t\t\tconst c = d.coverage  || {};\n\t\t\t\tconst w = d.winRate   || {};\n\t\t\t\tconst a = d.activity  || {};\n\t\t\t\tconst st = d.stale    || {};\n\n\t\t\t\tconst container = document.getElementById('cards');\n\t\t\t\tcontainer.innerHTML = '';\n\n\t\t\t\t// ── Card 1: Bookings Attainment ──────────────────────────────────────\n\t\t\t\tconst bAtt   = b.attainment || 0;\n\t\t\t\tconst bFill  = clamp(bAtt, 0, 100);\n\t\t\t\tconst bColor = b.status || 'neutral';\n\t\t\t\tconst forecastPct = b.target > 0 ? Math.round((b.forecast / b.target) * 100) : 0;\n\n\t\t\t\tcontainer.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Bookings Attainment</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(bAtt)}</div>\n          <div class=\"badge ${bColor}\">${statusLabel(bColor)}</div>\n\t\t\t</div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Gebucht</span><span class=\"sub-value\">${fmt(b.arr)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Ziel (Quartal)</span><span class=\"sub-value\">${fmt(b.target)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Self-Service</span><span class=\"sub-value\">${fmt(b.selfSvcARR)} (${pct(b.selfSvcPct)})</span></div>\n\t\t\t</div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\">\n            <span>Run Rate Forecast: ${pct(forecastPct)}</span>\n            <span>${fmt(b.forecast)} / ${fmt(b.target)}</span>\n\t\t\t</div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${bColor}\" style=\"width:${clamp(forecastPct,0,100)}%\"></div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>`;\n\n\t\t\t\t// ── Card 2: Pipeline Coverage ─────────────────────────────────────────\n\t\t\t\tconst covVal   = c.value || 0;\n\t\t\t\tconst covColor = c.status || 'neutral';\n\t\t\t\tconst covFill  = clamp((covVal / 3) * 100, 0, 100);\n\n\t\t\t\tcontainer.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Pipeline Coverage</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${covVal.toFixed(1).replace('.',',')}x</div>\n          <div class=\"badge ${covColor}\">${statusLabel(covColor)}</div>\n\t\t\t</div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Open Pipeline</span><span class=\"sub-value\">${fmt(c.pipelineARR)}</span></div>\n\t\t\t</div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0x</span><span>Ziel: 2,5x</span><span>3x</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${covColor}\" style=\"width:${covFill}%\"></div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>`;\n\n\t\t\t\t// ── Card 3: Win Rate ──────────────────────────────────────────────────\n\t\t\t\tconst wrVal   = w.value || 0;\n\t\t\t\tconst wrColor = w.status || 'neutral';\n\t\t\t\tconst wrFill  = clamp(wrVal, 0, 100);\n\n\t\t\t\tcontainer.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Win Rate</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(wrVal)}</div>\n          <div class=\"badge ${wrColor}\">${statusLabel(wrColor)}</div>\n\t\t\t</div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Gewonnen</span><span class=\"sub-value green\">${fmtN(w.wonCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Verloren</span><span class=\"sub-value red\">${fmtN(w.lostCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Gesamt (90d)</span><span class=\"sub-value\">${fmtN((w.wonCount||0)+(w.lostCount||0))}</span></div>\n\t\t\t</div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0%</span><span>Ziel: 30%</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${wrColor}\" style=\"width:${wrFill}%\"></div>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>`;\n\n\t\t\t\t// ── Card 4: Aktivität & Qual. Conversations ───────────────────────────\n\t\t\t\tconst maxDials = Math.max(a.dials || 1, 1);\n\t\t\t\tconst qualTotal = (a.qualCalls || 0) + (a.meetings || 0);\n\n\t\t\t\tcontainer.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Aktivität</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${fmtN(qualTotal)}</div>\n          <div class=\"badge blue\">Qual. Conv.</div>\n\t\t\t</div>\n        <div class=\"divider\"></div>\n        <div class=\"funnel\">\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Anwahlen</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:100%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.dials)}</span>\n\t\t\t</div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Qual. Calls</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.qualCalls||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.qualCalls)}</span>\n\t\t\t</div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Meetings</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.meetings||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.meetings)}</span>\n\t\t\t</div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">E-Mails</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.emails||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.emails)}</span>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>`;\n\n\t\t\t\t// ── Card 5: Stale Pipeline ────────────────────────────────────────────\n\t\t\t\tconst stColor = st.status || 'neutral';\n\t\t\t\tconst buckets = { '14-21d': 0, '21-30d': 0, '30d+': 0 };\n\t\t\t\t(st.list || []).forEach(o => {\n\t\t\t\t\tif (o.daysSinceActivity >= 30)      buckets['30d+']++;\n\t\t\t\t\telse if (o.daysSinceActivity >= 21) buckets['21-30d']++;\n\t\t\t\t\telse                                buckets['14-21d']++;\n\t\t\t\t});\n\n\t\t\t\tcontainer.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Stale Pipeline</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(st.value)}</div>\n          <div class=\"badge ${stColor}\">${statusLabel(stColor)}</div>\n\t\t\t</div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Stale Opps</span><span class=\"sub-value ${stColor}\">${fmtN(st.staleCount)} von ${fmtN(st.totalOpen)}</span></div>\n\t\t\t</div>\n        <div class=\"buckets\">\n          <div class=\"bucket b1\"><div class=\"bucket-val\">${buckets['14-21d']}</div><div class=\"bucket-label\">14–21d</div></div>\n          <div class=\"bucket b2\"><div class=\"bucket-val\">${buckets['21-30d']}</div><div class=\"bucket-label\">21–30d</div></div>\n          <div class=\"bucket b3\"><div class=\"bucket-val\">${buckets['30d+']}</div><div class=\"bucket-label\">30d+</div></div>\n\t\t\t</div>\n\t\t\t</div>`;\n\t\t\t}\n\n\t\t\t// Bootstrap\n\t\t\tif (typeof appsmith !== 'undefined') {\n\t\t\t\tappsmith.onReady(() => render(appsmith.model || {}));\n\t\t\t\tappsmith.onModelChange((m) => render(m || {}));\n\t\t\t} else {\n\t\t\t\trender({});\n\t\t\t}\n\t\t</script>\n\t</body>\n</html>",
    "js": "function _extends() { return _extends = Object.assign ? Object.assign.bind() : function (n) { for (var e = 1; e < arguments.length; e++) { var t = arguments[e]; for (var r in t) ({}).hasOwnProperty.call(t, r) && (n[r] = t[r]); } return n; }, _extends.apply(null, arguments); }\nimport React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\nconst Button = ({\n  children,\n  className,\n  ...props\n}) => /*#__PURE__*/React.createElement(\"button\", _extends({\n  className: className\n}, props), children);\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n  const handleNext = () => {\n    setCurrentIndex(prevIndex => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"app\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-header\"\n  }, /*#__PURE__*/React.createElement(\"h2\", null, \"Custom Widget\"), /*#__PURE__*/React.createElement(\"div\", null, currentIndex + 1, \" / \", appsmith.model.tips.length)), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"content\"\n  }, appsmith.model.tips[currentIndex])), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"button-container\"\n  }, /*#__PURE__*/React.createElement(Button, {\n    className: \"primary\",\n    onClick: handleNext\n  }, \"Next Tip\"), /*#__PURE__*/React.createElement(Button, {\n    className: \"reset\",\n    disabled: currentIndex === 0,\n    onClick: handleReset\n  }, \"Reset\")));\n}\nappsmith.onReady(() => {\n  /*\n  \t * This handler function will get called when parent application is ready.\n  \t * Initialize your component here\n  \t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n  \t */\n  ReactDOM.render(/*#__PURE__*/React.createElement(App, null), document.getElementById(\"root\"));\n});"
