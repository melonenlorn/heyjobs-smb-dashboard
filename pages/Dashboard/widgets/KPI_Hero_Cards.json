    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #222244;\n    --bg-hover:   #2a2a50;\n    --bg-surface: #16162b;\n    --text-1:     #f0f0f5;\n    --text-2:     #a0a0bb;\n    --text-3:     #6e6e88;\n    --green:      #58cc02;\n    --green-bg:   rgba(88,204,2,0.12);\n    --amber:      #ff9600;\n    --amber-bg:   rgba(255,150,0,0.12);\n    --red:        #ff4b4b;\n    --red-bg:     rgba(255,75,75,0.12);\n    --blue:       #1cb0f6;\n    --blue-bg:    rgba(28,176,246,0.12);\n    --border:     rgba(255,255,255,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body {\n    background: transparent;\n    font-family: var(--font);\n    color: var(--text-1);\n    padding: 4px;\n  }\n\n  .cards {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 10px;\n  }\n\n  .card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 16px;\n    cursor: default;\n    transition: border-color .2s, background .2s;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .card:hover { background: var(--bg-hover); border-color: rgba(255,255,255,0.18); }\n\n  .card-label {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n  }\n\n  .card-main {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n  }\n\n  .card-value {\n    font-size: 28px;\n    font-weight: 900;\n    line-height: 1;\n    color: var(--text-1);\n  }\n\n  .badge {\n    font-size: 11px;\n    font-weight: 800;\n    padding: 3px 9px;\n    border-radius: 20px;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(255,255,255,0.06); color: var(--text-3); }\n\n  .divider {\n    height: 1px;\n    background: var(--border);\n  }\n\n  .sub-metrics { display: flex; flex-direction: column; gap: 6px; }\n\n  .sub-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 12px;\n  }\n  .sub-label { color: var(--text-3); }\n  .sub-value { color: var(--text-2); font-weight: 700; }\n  .sub-value.green  { color: var(--green); }\n  .sub-value.amber  { color: var(--amber); }\n  .sub-value.red    { color: var(--red);   }\n\n  /* Progress bar */\n  .progress-wrap { display: flex; flex-direction: column; gap: 4px; }\n  .progress-labels {\n    display: flex;\n    justify-content: space-between;\n    font-size: 10px;\n    color: var(--text-3);\n  }\n  .progress-track {\n    height: 6px;\n    background: rgba(255,255,255,0.08);\n    border-radius: 99px;\n    overflow: hidden;\n    position: relative;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n    transition: width .4s ease;\n  }\n  .progress-fill.green { background: var(--green); }\n  .progress-fill.amber { background: var(--amber); }\n  .progress-fill.red   { background: var(--red);   }\n  .progress-fill.blue  { background: var(--blue);  }\n\n  /* Funnel bars */\n  .funnel { display: flex; flex-direction: column; gap: 4px; }\n  .funnel-row { display: flex; align-items: center; gap: 6px; font-size: 11px; }\n  .funnel-label { color: var(--text-3); width: 64px; flex-shrink: 0; }\n  .funnel-track { flex: 1; height: 5px; background: rgba(255,255,255,0.08); border-radius: 99px; overflow: hidden; }\n  .funnel-fill  { height: 100%; border-radius: 99px; background: var(--blue); }\n  .funnel-val   { color: var(--text-2); font-weight: 700; width: 36px; text-align: right; flex-shrink: 0; }\n\n  /* Stale buckets */\n  .buckets { display: flex; gap: 6px; }\n  .bucket  { flex: 1; background: rgba(255,255,255,0.05); border-radius: 8px; padding: 6px 4px; text-align: center; }\n  .bucket-val   { font-size: 15px; font-weight: 800; }\n  .bucket-label { font-size: 10px; color: var(--text-3); margin-top: 2px; }\n  .bucket.b1 .bucket-val { color: var(--amber); }\n  .bucket.b2 .bucket-val { color: var(--red);   }\n  .bucket.b3 .bucket-val { color: #cc3c3c;      }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 20px; }\n</style>\n</head>\n<body>\n\n<div class=\"cards\" id=\"cards\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function fmt(n) {\n    if (!n || n === 0) return '€\\u00a00';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return '€\\u00a0' + (abs / 1000000).toFixed(1).replace('.', ',') + ' Mio.';\n    if (abs >= 1000)    return '€\\u00a0' + Math.round(abs / 1000) + 'k';\n    return '€\\u00a0' + abs.toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function fmtN(n) {\n    return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function statusLabel(s) {\n    return { green: 'Gesund', amber: 'Warnung', red: 'Kritisch' }[s] || '—';\n  }\n\n  function render(model) {\n    const d = model || {};\n    const b = d.bookings  || {};\n    const c = d.coverage  || {};\n    const w = d.winRate   || {};\n    const a = d.activity  || {};\n    const st = d.stale    || {};\n\n    const container = document.getElementById('cards');\n    container.innerHTML = '';\n\n    // ── Card 1: Bookings Attainment ──────────────────────────────────────\n    const bAtt   = b.attainment || 0;\n    const bFill  = clamp(bAtt, 0, 100);\n    const bColor = b.status || 'neutral';\n    const forecastPct = b.target > 0 ? Math.round((b.forecast / b.target) * 100) : 0;\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Bookings Attainment</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(bAtt)}</div>\n          <div class=\"badge ${bColor}\">${statusLabel(bColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Gebucht</span><span class=\"sub-value\">${fmt(b.arr)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Ziel (Quartal)</span><span class=\"sub-value\">${fmt(b.target)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Self-Service</span><span class=\"sub-value\">${fmt(b.selfSvcARR)} (${pct(b.selfSvcPct)})</span></div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\">\n            <span>Run Rate Forecast: ${pct(forecastPct)}</span>\n            <span>${fmt(b.forecast)} / ${fmt(b.target)}</span>\n          </div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${bColor}\" style=\"width:${clamp(forecastPct,0,100)}%\"></div>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 2: Pipeline Coverage ─────────────────────────────────────────\n    const covVal   = c.value || 0;\n    const covColor = c.status || 'neutral';\n    const covFill  = clamp((covVal / 3) * 100, 0, 100);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Pipeline Coverage</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${covVal.toFixed(1).replace('.',',')}x</div>\n          <div class=\"badge ${covColor}\">${statusLabel(covColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Open Pipeline</span><span class=\"sub-value\">${fmt(c.pipelineARR)}</span></div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0x</span><span>Ziel: 2,5x</span><span>3x</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${covColor}\" style=\"width:${covFill}%\"></div>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 3: Win Rate ──────────────────────────────────────────────────\n    const wrVal   = w.value || 0;\n    const wrColor = w.status || 'neutral';\n    const wrFill  = clamp(wrVal, 0, 100);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Win Rate</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(wrVal)}</div>\n          <div class=\"badge ${wrColor}\">${statusLabel(wrColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Gewonnen</span><span class=\"sub-value green\">${fmtN(w.wonCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Verloren</span><span class=\"sub-value red\">${fmtN(w.lostCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Gesamt (90d)</span><span class=\"sub-value\">${fmtN((w.wonCount||0)+(w.lostCount||0))}</span></div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0%</span><span>Ziel: 30%</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${wrColor}\" style=\"width:${wrFill}%\"></div>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 4: Aktivität & Qual. Conversations ───────────────────────────\n    const maxDials = Math.max(a.dials || 1, 1);\n    const qualTotal = (a.qualCalls || 0) + (a.meetings || 0);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Aktivität</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${fmtN(qualTotal)}</div>\n          <div class=\"badge blue\">Qual. Conv.</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"funnel\">\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Anwahlen</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:100%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.dials)}</span>\n          </div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Qual. Calls</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.qualCalls||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.qualCalls)}</span>\n          </div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">Meetings</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.meetings||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.meetings)}</span>\n          </div>\n          <div class=\"funnel-row\">\n            <span class=\"funnel-label\">E-Mails</span>\n            <div class=\"funnel-track\"><div class=\"funnel-fill\" style=\"width:${clamp(((a.emails||0)/maxDials)*100,0,100)}%\"></div></div>\n            <span class=\"funnel-val\">${fmtN(a.emails)}</span>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 5: Stale Pipeline ────────────────────────────────────────────\n    const stColor = st.status || 'neutral';\n    const buckets = { '14-21d': 0, '21-30d': 0, '30d+': 0 };\n    (st.list || []).forEach(o => {\n      if (o.daysSinceActivity >= 30)      buckets['30d+']++;\n      else if (o.daysSinceActivity >= 21) buckets['21-30d']++;\n      else                                buckets['14-21d']++;\n    });\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Stale Pipeline</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(st.value)}</div>\n          <div class=\"badge ${stColor}\">${statusLabel(stColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Stale Opps</span><span class=\"sub-value ${stColor}\">${fmtN(st.staleCount)} von ${fmtN(st.totalOpen)}</span></div>\n        </div>\n        <div class=\"buckets\">\n          <div class=\"bucket b1\"><div class=\"bucket-val\">${buckets['14-21d']}</div><div class=\"bucket-label\">14–21d</div></div>\n          <div class=\"bucket b2\"><div class=\"bucket-val\">${buckets['21-30d']}</div><div class=\"bucket-label\">21–30d</div></div>\n          <div class=\"bucket b3\"><div class=\"bucket-val\">${buckets['30d+']}</div><div class=\"bucket-label\">30d+</div></div>\n        </div>\n      </div>`;\n  }\n\n  // Bootstrap\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = JSON.stringify(appsmith.model.bookings);\n      if (key !== _lastKey) { _lastKey = key; render(appsmith.model); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(appsmith.model || {}); poll(); });\n    appsmith.onModelChange((m) => render(m || {}));\n  } else {\n    render({});\n  }\n</script>\n</body>\n</html>",
    "js": "appsmith.onReady(() => { if (typeof render === 'function') { render(appsmith.model || {}); } if (typeof poll === 'function') { poll(); } });"
  },
  "version": 1,
  "widgetId": "xuaa1u5nyj",
  "widgetName": "KPI_Hero_Cards"
}