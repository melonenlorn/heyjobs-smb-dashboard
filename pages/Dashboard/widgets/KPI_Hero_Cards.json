{
  "backgroundColor": "#FFFFFF",
  "borderColor": "#E0DEDE",
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "borderWidth": "1",
  "bottomRow": 30,
  "boxShadow": "{{appsmith.theme.boxShadow.appBoxShadow}}",
  "defaultModel": "{{(function(){var t=appsmith.store.filterTeam;var _=[Q_Bookings_QTD.data,Q_SelfService_QTD.data,Q_Pipeline_Open.data,Q_Pilots_Open.data,Q_Stale_Pipeline.data,Q_WinLoss.data,Q_Calls_QTD.data,Q_QualCalls_QTD.data,Q_Emails_QTD.data,Q_Meetings_QTD.data,Q_Quotas.data,Q_Users_Team.data,Q_Opps_Created_QTD.data,Q_Calls_CW.data,Q_Calls_PW.data,Q_QualCalls_CW.data,Q_QualCalls_PW.data,Q_Emails_CW.data,Q_Emails_PW.data,Q_Meetings_CW.data,Q_Meetings_PW.data,Q_Demos_QTD.data];return JS_Data.heroKPIs();})()}}",
  "dynamicBindingPathList": [
    {
      "key": "theme"
    },
    {
      "key": "borderRadius"
    },
    {
      "key": "boxShadow"
    },
    {
      "key": "defaultModel"
    }
  ],
  "dynamicHeight": "FIXED",
  "dynamicTriggerPathList": [
    {
      "key": "onResetClick"
    }
  ],
  "events": [
    "onResetClick"
  ],
  "isCanvas": false,
  "isLoading": false,
  "isSearchWildcard": true,
  "isVisible": true,
  "key": "ienb1o9xwk",
  "leftColumn": 0,
  "maxDynamicHeight": 9000,
  "minDynamicHeight": 4,
  "mobileBottomRow": 36,
  "mobileLeftColumn": 0,
  "mobileRightColumn": 12,
  "mobileTopRow": 6,
  "needsErrorInfo": false,
  "onResetClick": "{{showAlert('Successfully reset!!', '');}}",
  "parentColumnSpace": 13.1875,
  "parentId": "0",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "rightColumn": 64,
  "srcDoc": {
    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-hover:   #f4f4ff;\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body {\n    background: transparent;\n    font-family: var(--font);\n    color: var(--text-1);\n    padding: 4px;\n  }\n\n  .cards {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 10px;\n  }\n\n  .card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 16px;\n    cursor: default;\n    transition: border-color .2s, background .2s;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n  .card:hover { background: var(--bg-hover); border-color: rgba(0,0,0,0.14); }\n\n  .card-label {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n  }\n\n  .card-main {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n  }\n\n  .card-value {\n    font-size: 28px;\n    font-weight: 900;\n    line-height: 1;\n    color: var(--text-1);\n  }\n\n  .badge {\n    font-size: 11px;\n    font-weight: 800;\n    padding: 3px 9px;\n    border-radius: 20px;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(0,0,0,0.05); color: var(--text-3); }\n\n  .divider {\n    height: 1px;\n    background: var(--border);\n  }\n\n  .sub-metrics { display: flex; flex-direction: column; gap: 6px; }\n\n  .sub-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 12px;\n  }\n  .sub-label { color: var(--text-3); }\n  .sub-value { color: var(--text-2); font-weight: 700; }\n  .sub-value.green  { color: var(--green); }\n  .sub-value.amber  { color: var(--amber); }\n  .sub-value.red    { color: var(--red);   }\n  .sub-value.blue   { color: var(--blue);  }\n\n  /* Progress bar */\n  .progress-wrap { display: flex; flex-direction: column; gap: 4px; }\n  .progress-labels {\n    display: flex;\n    justify-content: space-between;\n    font-size: 10px;\n    color: var(--text-3);\n  }\n  .progress-track {\n    height: 6px;\n    background: rgba(0,0,0,0.07);\n    border-radius: 99px;\n    overflow: hidden;\n    position: relative;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n    transition: width .4s ease;\n  }\n  .progress-fill.green { background: var(--green); }\n  .progress-fill.amber { background: var(--amber); }\n  .progress-fill.red   { background: var(--red);   }\n  .progress-fill.blue  { background: var(--blue);  }\n\n  /* Funnel bars */\n  .funnel { display: flex; flex-direction: column; gap: 4px; }\n  .funnel-row { display: flex; align-items: center; gap: 6px; font-size: 11px; }\n  .funnel-label { color: var(--text-3); width: 72px; flex-shrink: 0; }\n  .funnel-track { flex: 1; height: 5px; background: rgba(0,0,0,0.07); border-radius: 99px; overflow: hidden; }\n  .funnel-fill  { height: 100%; border-radius: 99px; background: var(--blue); }\n  .funnel-val   { color: var(--text-2); font-weight: 700; width: 36px; text-align: right; flex-shrink: 0; }\n\n  /* Stale buckets */\n  .buckets { display: flex; gap: 6px; }\n  .bucket  { flex: 1; background: rgba(0,0,0,0.04); border-radius: 8px; padding: 6px 4px; text-align: center; }\n  .bucket-val   { font-size: 15px; font-weight: 800; }\n  .bucket-label { font-size: 10px; color: var(--text-3); margin-top: 2px; }\n  .bucket.b1 .bucket-val { color: var(--amber); }\n  .bucket.b2 .bucket-val { color: var(--red);   }\n  .bucket.b3 .bucket-val { color: #b02020;      }\n\n  .wow.green   { color: var(--green); }\n  .wow.red     { color: var(--red); }\n  .wow.neutral { color: var(--text-3); }\n\n  /* Coverage card extras */\n  .section-label { font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); }\n  .seg-row { display: flex; justify-content: space-between; align-items: center; font-size: 12px; }\n  .seg-name { color: var(--text-2); font-weight: 600; }\n  .seg-vals { display: flex; gap: 6px; align-items: center; font-weight: 700; color: var(--text-1); }\n  .seg-count { font-size: 11px; color: var(--text-3); font-weight: 500; }\n  .seg-bar { margin-top: 3px; height: 5px; }\n  .delta-badge { font-size: 11px; font-weight: 800; padding: 2px 7px; border-radius: 20px; flex-shrink: 0; }\n  .delta-badge.green { background: var(--green-bg); color: var(--green); }\n  .delta-badge.red   { background: var(--red-bg);   color: var(--red);   }\n  .delta-badge.neutral { background: rgba(0,0,0,0.05); color: var(--text-3); }\n  .wow-row { display: flex; gap: 5px; }\n  .wow-row .wow-item { flex: 1; }\n  .wow-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }\n  .wow-item { font-size: 11px; font-weight: 700; background: rgba(0,0,0,0.03); border-radius: 8px; padding: 5px 7px; display: flex; flex-direction: column; gap: 1px; }\n  .wow-item.green { background: var(--green-bg); color: var(--green); }\n  .wow-item.red   { background: var(--red-bg);   color: var(--red);   }\n  .wow-item.neutral { color: var(--text-2); }\n  .wow-item strong { font-size: 13px; font-weight: 900; }\n  .wow-item span   { font-size: 10px; opacity: .8; font-weight: 500; }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 20px; }\n</style>\n</head>\n<body>\n\n<div class=\"cards\" id=\"cards\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function fmt(n) {\n    if (!n || n === 0) return '€\\u00a00';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return '€\\u00a0' + (abs / 1000000).toFixed(1).replace('.', ',') + ' Mio.';\n    if (abs >= 1000)    return '€\\u00a0' + Math.round(abs / 1000) + 'k';\n    return '€\\u00a0' + abs.toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function fmtN(n) {\n    return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function statusLabel(s) {\n    return { green: 'Gesund', amber: 'Warnung', red: 'Kritisch' }[s] || '—';\n  }\n\n  function col(s) {\n    return { green: 'var(--green)', amber: 'var(--amber)', red: 'var(--red)' }[s] || 'var(--text-2)';\n  }\n\n  function render(model) {\n    const d = model || {};\n    const b = d.bookings  || {};\n    const c = d.coverage  || {};\n    const w = d.winRate   || {};\n    const a = d.activity  || {};\n    const st = d.stale    || {};\n    const comp = d.composite || {};\n    const p    = d.piloten   || {};\n\n    const container = document.getElementById('cards');\n    container.innerHTML = '';\n\n    // ── Card 1: Attainment (Composite) ──────────────────────────────────\n    const compVal    = comp.value    || 0;\n    const compFore   = comp.forecast || 0;\n    const compSt     = comp.status   || 'neutral';\n    const badgeCls   = compFore >= 100 ? 'green' : (compFore >= 80 ? 'amber' : 'red');\n    const compUplift = b.target > 0 ? Math.round(((c.wow && c.wow.wonCWArr) || 0) / b.target * 100 * 0.75) : 0;\n    const compUpliftCls = compUplift > 0 ? 'green' : (compUplift < 0 ? 'red' : 'neutral');\n    const compUpliftSign = compUplift > 0 ? '+' : '';\n\n    container.innerHTML += `\n      <div class=\"card\" style=\"gap:8px\">\n\n        <!-- header: label + Hochr badge -->\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <span class=\"card-label\">Attainment</span>\n          <span class=\"badge ${badgeCls}\" style=\"font-size:11px;padding:3px 9px\">Hochr. ${pct(compFore)}</span>\n        </div>\n\n        <!-- big composite number -->\n        <div style=\"text-align:center;padding:4px 0 0\">\n          <div style=\"display:inline-flex;align-items:flex-start;gap:6px;justify-content:center\">\n            <div style=\"font-size:56px;font-weight:900;line-height:1;color:${col(compSt)}\">${compVal}<span style=\"font-size:28px;font-weight:700;opacity:.6\"> %</span></div>\n            <span class=\"delta-badge ${compUpliftCls}\" style=\"margin-top:10px\">${compUpliftSign}${compUplift} pp</span>\n          </div>\n          <div style=\"font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.09em;margin-top:4px\">Composite</div>\n        </div>\n\n        <!-- bookings block -->\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:10px;padding:9px 11px;display:flex;flex-direction:column;gap:5px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Bookings</span>\n            <span style=\"font-size:10px;font-weight:700;color:var(--text-3)\">75 %</span>\n          </div>\n          <div style=\"display:flex;align-items:center;gap:7px\">\n            <div style=\"flex:1;height:5px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n              <div style=\"height:100%;border-radius:99px;width:${clamp(b.attainment||0,0,100)}%;background:${col(b.status||'neutral')}\"></div>\n            </div>\n            <span style=\"font-size:12px;font-weight:900;color:${col(b.status||'neutral')};min-width:40px;text-align:right\">TA ${pct(b.attainment)}</span>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:11px;color:var(--text-3)\">\n            <span>${fmt(b.arr)} <span style=\"opacity:.6\">/ ${fmt(b.target)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${pct(b.forecastAtt)}</span>\n          </div>\n        </div>\n\n        <!-- piloten block -->\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:10px;padding:9px 11px;display:flex;flex-direction:column;gap:5px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Piloten</span>\n            <span style=\"font-size:10px;font-weight:700;color:var(--text-3)\">25 %</span>\n          </div>\n          <div style=\"display:flex;align-items:center;gap:7px\">\n            <div style=\"flex:1;height:5px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n              <div style=\"height:100%;border-radius:99px;width:${clamp(p.attainment||0,0,100)}%;background:${col(p.status||'neutral')}\"></div>\n            </div>\n            <span style=\"font-size:12px;font-weight:900;color:${col(p.status||'neutral')};min-width:40px;text-align:right\">TA ${pct(p.attainment)}</span>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:11px;color:var(--text-3)\">\n            <span>${fmtN(p.count)} <span style=\"opacity:.6\">/ ${fmtN(p.target)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${fmtN(p.forecast)} (${pct(p.forecastAtt)})</span>\n          </div>\n        </div>\n\n      </div>`;\n\n        // ── Card 2: Pipeline Coverage ───────────────────────────────────────────────────────────────────────\n    const covVal     = c.value || 0;\n    const covColor   = c.status || 'neutral';\n    const covFill    = clamp((covVal / 3) * 100, 0, 100);\n    const cWow       = c.wow || {};\n    const totalPipe  = c.pipelineARR || 0;\n    const pilotPct   = totalPipe > 0 ? clamp(Math.round((c.pilotArr || 0) / totalPipe * 100), 0, 100) : 0;\n    const bestandPct = totalPipe > 0 ? clamp(Math.round((c.bestandArr || 0) / totalPipe * 100), 0, 100) : 0;\n    const netWow     = (cWow.newArr || 0) - (cWow.lostCWArr || 0);\n    const netSign    = netWow >= 0 ? '+' : '';\n    const netCls     = netWow >= 0 ? 'green' : 'red';\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Pipeline Coverage</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${covVal.toFixed(1).replace('.',',')}x</div>\n          <span class=\"delta-badge ${netCls}\">${netSign}${fmt(netWow)}</span>\n          <div class=\"badge ${covColor}\">${statusLabel(covColor)}</div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${covColor}\" style=\"width:${covFill}%\"></div>\n          </div>\n          <div class=\"progress-labels\"><span>0x</span><span>Ziel 2,5x</span><span>3x</span></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Zusammensetzung</div>\n        <div class=\"seg-row\">\n          <span class=\"seg-name\">Neugesch./Piloten</span>\n          <span class=\"seg-vals\">${fmt(c.pilotArr || 0)}<span class=\"seg-count\">${fmtN(c.pilotOpps || 0)} Deals</span></span>\n        </div>\n        <div class=\"progress-track seg-bar\">\n          <div class=\"progress-fill blue\" style=\"width:${pilotPct}%\"></div>\n        </div>\n        <div class=\"seg-row\" style=\"margin-top:5px\">\n          <span class=\"seg-name\">Bestandskunden</span>\n          <span class=\"seg-vals\">${fmt(c.bestandArr || 0)}<span class=\"seg-count\">${fmtN(c.bestandOpps || 0)} Deals</span></span>\n        </div>\n        <div class=\"progress-track seg-bar\">\n          <div class=\"progress-fill amber\" style=\"width:${bestandPct}%\"></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Diese Woche</div>\n        <div class=\"wow-row\">\n          <div class=\"wow-item green\">↑ Neu<strong>+${fmt(cWow.newArr||0)}</strong><span>${fmtN(cWow.newOpps||0)} Deals</span></div>\n          <div class=\"wow-item green\">✓ Won<strong>+${fmt(cWow.wonCWArr||0)}</strong><span>${fmtN(cWow.wonCW||0)} Deals</span></div>\n          <div class=\"wow-item red\">✗ Lost<strong>−${fmt(cWow.lostCWArr||0)}</strong><span>${fmtN(cWow.lostCW||0)} Deals</span></div>\n        </div>\n      </div>`;\n\n        // ── Card 3: Win Rate (excl. Self-Service) ────────────────────────────\n    const wrVal      = w.value || 0;\n    const wrColor    = w.status || 'neutral';\n    const wrFill     = clamp(wrVal, 0, 100);\n    const wrDemos    = w.demos || 0;\n    const wrD2O      = w.demoToOpp || 0;\n    const wrD2OFill  = clamp(wrD2O, 0, 100);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Win Rate (Rep-driven)</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(wrVal)}</div>\n          <div class=\"badge ${wrColor}\">${statusLabel(wrColor)}</div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0%</span><span>Ziel: 30%</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${wrColor}\" style=\"width:${wrFill}%\"></div>\n          </div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">✓ Gewonnen</span><span class=\"sub-value green\">${fmtN(w.wonCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">✗ Verloren</span><span class=\"sub-value red\">${fmtN(w.lostCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Gesamt (90d, excl. SS)</span><span class=\"sub-value\">${fmtN((w.wonCount||0)+(w.lostCount||0))}</span></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Demo → Opp</div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Demos</span><span class=\"sub-value\">${fmtN(wrDemos)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Opps erstellt</span><span class=\"sub-value\">${fmtN(w.oppCreated||0)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Conversion</span><span class=\"sub-value blue\">${pct(wrD2O)}</span></div>\n        </div>\n        <div class=\"progress-track\" style=\"height:5px\">\n          <div class=\"progress-fill blue\" style=\"width:${wrD2OFill}%\"></div>\n        </div>\n      </div>`;\n\n    // ── Card 4: Aktivität (WoW) ───────────────────────────────────────────\n    const qtConv = a.qtConv || 0;\n    const cwA    = a.cw || {};\n    const pwA    = a.pw || {};\n\n    function wowArrow(cw, pw) {\n      if (!pw || pw === 0) return { arrow: '→', cls: 'neutral' };\n      const delta = ((cw - pw) / pw) * 100;\n      if (delta > 3)  return { arrow: '↑', cls: 'green' };\n      if (delta < -3) return { arrow: '↓', cls: 'red' };\n      return { arrow: '→', cls: 'neutral' };\n    }\n\n    const dialWoW  = wowArrow(cwA.dials     || 0, pwA.dials     || 0);\n    const qcWoW    = wowArrow(cwA.qualCalls || 0, pwA.qualCalls || 0);\n    const mtgWoW   = wowArrow(cwA.meetings  || 0, pwA.meetings  || 0);\n    const emailWoW = wowArrow(cwA.emails    || 0, pwA.emails    || 0);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Aktivität</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(qtConv)}</div>\n          <div class=\"badge blue\">QT→Opp</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Anwahlen/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.dials || 0)} <span class=\"wow ${dialWoW.cls}\">${dialWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Qual.Calls/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.qualCalls || 0)} <span class=\"wow ${qcWoW.cls}\">${qcWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Meetings/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.meetings || 0)} <span class=\"wow ${mtgWoW.cls}\">${mtgWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Mails/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.emails || 0)} <span class=\"wow ${emailWoW.cls}\">${emailWoW.arrow}</span></span>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 5: Stale Pipeline ────────────────────────────────────────────\n    const stColor = st.status || 'neutral';\n    const buckets = { '14-21d': 0, '21-30d': 0, '30d+': 0 };\n    (st.list || []).forEach(o => {\n      if (o.daysSinceActivity >= 30)      buckets['30d+']++;\n      else if (o.daysSinceActivity >= 21) buckets['21-30d']++;\n      else                                buckets['14-21d']++;\n    });\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Stale Pipeline</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(st.value)}</div>\n          <div class=\"badge ${stColor}\">${statusLabel(stColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Stale Opps</span><span class=\"sub-value ${stColor}\">${fmtN(st.staleCount)} von ${fmtN(st.totalOpen)}</span></div>\n        </div>\n        <div class=\"buckets\">\n          <div class=\"bucket b1\"><div class=\"bucket-val\">${buckets['14-21d']}</div><div class=\"bucket-label\">14–21d</div></div>\n          <div class=\"bucket b2\"><div class=\"bucket-val\">${buckets['21-30d']}</div><div class=\"bucket-label\">21–30d</div></div>\n          <div class=\"bucket b3\"><div class=\"bucket-val\">${buckets['30d+']}</div><div class=\"bucket-label\">30d+</div></div>\n        </div>\n      </div>`;\n  }\n\n  // Bootstrap\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = JSON.stringify([appsmith.model.bookings, appsmith.model.composite]);\n      if (key !== _lastKey) { _lastKey = key; render(appsmith.model); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(appsmith.model || {}); poll(); });\n    appsmith.onModelChange((m) => render(m || {}));\n  } else {\n    render({});\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => {\n  if (typeof render === 'function') {\n    render(appsmith.model || {});\n  }\n  if (typeof poll === 'function') {\n    poll();\n  }\n});"
  },
  "theme": "{{appsmith.theme}}",
  "topRow": 0,
  "type": "CUSTOM_WIDGET",
  "uncompiledSrcDoc": {
    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-hover:   #f4f4ff;\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body {\n    background: transparent;\n    font-family: var(--font);\n    color: var(--text-1);\n    padding: 4px;\n  }\n\n  .cards {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 10px;\n  }\n\n  .card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 16px;\n    cursor: default;\n    transition: border-color .2s, background .2s;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n  .card:hover { background: var(--bg-hover); border-color: rgba(0,0,0,0.14); }\n\n  .card-label {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n  }\n\n  .card-main {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 8px;\n  }\n\n  .card-value {\n    font-size: 28px;\n    font-weight: 900;\n    line-height: 1;\n    color: var(--text-1);\n  }\n\n  .badge {\n    font-size: 11px;\n    font-weight: 800;\n    padding: 3px 9px;\n    border-radius: 20px;\n    white-space: nowrap;\n    flex-shrink: 0;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(0,0,0,0.05); color: var(--text-3); }\n\n  .divider {\n    height: 1px;\n    background: var(--border);\n  }\n\n  .sub-metrics { display: flex; flex-direction: column; gap: 6px; }\n\n  .sub-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 12px;\n  }\n  .sub-label { color: var(--text-3); }\n  .sub-value { color: var(--text-2); font-weight: 700; }\n  .sub-value.green  { color: var(--green); }\n  .sub-value.amber  { color: var(--amber); }\n  .sub-value.red    { color: var(--red);   }\n  .sub-value.blue   { color: var(--blue);  }\n\n  /* Progress bar */\n  .progress-wrap { display: flex; flex-direction: column; gap: 4px; }\n  .progress-labels {\n    display: flex;\n    justify-content: space-between;\n    font-size: 10px;\n    color: var(--text-3);\n  }\n  .progress-track {\n    height: 6px;\n    background: rgba(0,0,0,0.07);\n    border-radius: 99px;\n    overflow: hidden;\n    position: relative;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n    transition: width .4s ease;\n  }\n  .progress-fill.green { background: var(--green); }\n  .progress-fill.amber { background: var(--amber); }\n  .progress-fill.red   { background: var(--red);   }\n  .progress-fill.blue  { background: var(--blue);  }\n\n  /* Funnel bars */\n  .funnel { display: flex; flex-direction: column; gap: 4px; }\n  .funnel-row { display: flex; align-items: center; gap: 6px; font-size: 11px; }\n  .funnel-label { color: var(--text-3); width: 72px; flex-shrink: 0; }\n  .funnel-track { flex: 1; height: 5px; background: rgba(0,0,0,0.07); border-radius: 99px; overflow: hidden; }\n  .funnel-fill  { height: 100%; border-radius: 99px; background: var(--blue); }\n  .funnel-val   { color: var(--text-2); font-weight: 700; width: 36px; text-align: right; flex-shrink: 0; }\n\n  /* Stale buckets */\n  .buckets { display: flex; gap: 6px; }\n  .bucket  { flex: 1; background: rgba(0,0,0,0.04); border-radius: 8px; padding: 6px 4px; text-align: center; }\n  .bucket-val   { font-size: 15px; font-weight: 800; }\n  .bucket-label { font-size: 10px; color: var(--text-3); margin-top: 2px; }\n  .bucket.b1 .bucket-val { color: var(--amber); }\n  .bucket.b2 .bucket-val { color: var(--red);   }\n  .bucket.b3 .bucket-val { color: #b02020;      }\n\n  .wow.green   { color: var(--green); }\n  .wow.red     { color: var(--red); }\n  .wow.neutral { color: var(--text-3); }\n\n  /* Coverage card extras */\n  .section-label { font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); }\n  .seg-row { display: flex; justify-content: space-between; align-items: center; font-size: 12px; }\n  .seg-name { color: var(--text-2); font-weight: 600; }\n  .seg-vals { display: flex; gap: 6px; align-items: center; font-weight: 700; color: var(--text-1); }\n  .seg-count { font-size: 11px; color: var(--text-3); font-weight: 500; }\n  .seg-bar { margin-top: 3px; height: 5px; }\n  .delta-badge { font-size: 11px; font-weight: 800; padding: 2px 7px; border-radius: 20px; flex-shrink: 0; }\n  .delta-badge.green { background: var(--green-bg); color: var(--green); }\n  .delta-badge.red   { background: var(--red-bg);   color: var(--red);   }\n  .delta-badge.neutral { background: rgba(0,0,0,0.05); color: var(--text-3); }\n  .wow-row { display: flex; gap: 5px; }\n  .wow-row .wow-item { flex: 1; }\n  .wow-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; }\n  .wow-item { font-size: 11px; font-weight: 700; background: rgba(0,0,0,0.03); border-radius: 8px; padding: 5px 7px; display: flex; flex-direction: column; gap: 1px; }\n  .wow-item.green { background: var(--green-bg); color: var(--green); }\n  .wow-item.red   { background: var(--red-bg);   color: var(--red);   }\n  .wow-item.neutral { color: var(--text-2); }\n  .wow-item strong { font-size: 13px; font-weight: 900; }\n  .wow-item span   { font-size: 10px; opacity: .8; font-weight: 500; }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 20px; }\n</style>\n</head>\n<body>\n\n<div class=\"cards\" id=\"cards\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function fmt(n) {\n    if (!n || n === 0) return '€\\u00a00';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return '€\\u00a0' + (abs / 1000000).toFixed(1).replace('.', ',') + ' Mio.';\n    if (abs >= 1000)    return '€\\u00a0' + Math.round(abs / 1000) + 'k';\n    return '€\\u00a0' + abs.toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function fmtN(n) {\n    return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.');\n  }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function statusLabel(s) {\n    return { green: 'Gesund', amber: 'Warnung', red: 'Kritisch' }[s] || '—';\n  }\n\n  function col(s) {\n    return { green: 'var(--green)', amber: 'var(--amber)', red: 'var(--red)' }[s] || 'var(--text-2)';\n  }\n\n  function render(model) {\n    const d = model || {};\n    const b = d.bookings  || {};\n    const c = d.coverage  || {};\n    const w = d.winRate   || {};\n    const a = d.activity  || {};\n    const st = d.stale    || {};\n    const comp = d.composite || {};\n    const p    = d.piloten   || {};\n\n    const container = document.getElementById('cards');\n    container.innerHTML = '';\n\n    // ── Card 1: Attainment (Composite) ──────────────────────────────────\n    const compVal    = comp.value    || 0;\n    const compFore   = comp.forecast || 0;\n    const compSt     = comp.status   || 'neutral';\n    const badgeCls   = compFore >= 100 ? 'green' : (compFore >= 80 ? 'amber' : 'red');\n    const compUplift = b.target > 0 ? Math.round(((c.wow && c.wow.wonCWArr) || 0) / b.target * 100 * 0.75) : 0;\n    const compUpliftCls = compUplift > 0 ? 'green' : (compUplift < 0 ? 'red' : 'neutral');\n    const compUpliftSign = compUplift > 0 ? '+' : '';\n\n    container.innerHTML += `\n      <div class=\"card\" style=\"gap:8px\">\n\n        <!-- header: label + Hochr badge -->\n        <div style=\"display:flex;justify-content:space-between;align-items:center\">\n          <span class=\"card-label\">Attainment</span>\n          <span class=\"badge ${badgeCls}\" style=\"font-size:11px;padding:3px 9px\">Hochr. ${pct(compFore)}</span>\n        </div>\n\n        <!-- big composite number -->\n        <div style=\"text-align:center;padding:4px 0 0\">\n          <div style=\"display:inline-flex;align-items:flex-start;gap:6px;justify-content:center\">\n            <div style=\"font-size:56px;font-weight:900;line-height:1;color:${col(compSt)}\">${compVal}<span style=\"font-size:28px;font-weight:700;opacity:.6\"> %</span></div>\n            <span class=\"delta-badge ${compUpliftCls}\" style=\"margin-top:10px\">${compUpliftSign}${compUplift} pp</span>\n          </div>\n          <div style=\"font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.09em;margin-top:4px\">Composite</div>\n        </div>\n\n        <!-- bookings block -->\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:10px;padding:9px 11px;display:flex;flex-direction:column;gap:5px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Bookings</span>\n            <span style=\"font-size:10px;font-weight:700;color:var(--text-3)\">75 %</span>\n          </div>\n          <div style=\"display:flex;align-items:center;gap:7px\">\n            <div style=\"flex:1;height:5px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n              <div style=\"height:100%;border-radius:99px;width:${clamp(b.attainment||0,0,100)}%;background:${col(b.status||'neutral')}\"></div>\n            </div>\n            <span style=\"font-size:12px;font-weight:900;color:${col(b.status||'neutral')};min-width:40px;text-align:right\">TA ${pct(b.attainment)}</span>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:11px;color:var(--text-3)\">\n            <span>${fmt(b.arr)} <span style=\"opacity:.6\">/ ${fmt(b.target)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${pct(b.forecastAtt)}</span>\n          </div>\n        </div>\n\n        <!-- piloten block -->\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:10px;padding:9px 11px;display:flex;flex-direction:column;gap:5px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Piloten</span>\n            <span style=\"font-size:10px;font-weight:700;color:var(--text-3)\">25 %</span>\n          </div>\n          <div style=\"display:flex;align-items:center;gap:7px\">\n            <div style=\"flex:1;height:5px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n              <div style=\"height:100%;border-radius:99px;width:${clamp(p.attainment||0,0,100)}%;background:${col(p.status||'neutral')}\"></div>\n            </div>\n            <span style=\"font-size:12px;font-weight:900;color:${col(p.status||'neutral')};min-width:40px;text-align:right\">TA ${pct(p.attainment)}</span>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:11px;color:var(--text-3)\">\n            <span>${fmtN(p.count)} <span style=\"opacity:.6\">/ ${fmtN(p.target)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${fmtN(p.forecast)} (${pct(p.forecastAtt)})</span>\n          </div>\n        </div>\n\n      </div>`;\n\n        // ── Card 2: Pipeline Coverage ───────────────────────────────────────────────────────────────────────\n    const covVal     = c.value || 0;\n    const covColor   = c.status || 'neutral';\n    const covFill    = clamp((covVal / 3) * 100, 0, 100);\n    const cWow       = c.wow || {};\n    const totalPipe  = c.pipelineARR || 0;\n    const pilotPct   = totalPipe > 0 ? clamp(Math.round((c.pilotArr || 0) / totalPipe * 100), 0, 100) : 0;\n    const bestandPct = totalPipe > 0 ? clamp(Math.round((c.bestandArr || 0) / totalPipe * 100), 0, 100) : 0;\n    const netWow     = (cWow.newArr || 0) - (cWow.lostCWArr || 0);\n    const netSign    = netWow >= 0 ? '+' : '';\n    const netCls     = netWow >= 0 ? 'green' : 'red';\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Pipeline Coverage</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${covVal.toFixed(1).replace('.',',')}x</div>\n          <span class=\"delta-badge ${netCls}\">${netSign}${fmt(netWow)}</span>\n          <div class=\"badge ${covColor}\">${statusLabel(covColor)}</div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${covColor}\" style=\"width:${covFill}%\"></div>\n          </div>\n          <div class=\"progress-labels\"><span>0x</span><span>Ziel 2,5x</span><span>3x</span></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Zusammensetzung</div>\n        <div class=\"seg-row\">\n          <span class=\"seg-name\">Neugesch./Piloten</span>\n          <span class=\"seg-vals\">${fmt(c.pilotArr || 0)}<span class=\"seg-count\">${fmtN(c.pilotOpps || 0)} Deals</span></span>\n        </div>\n        <div class=\"progress-track seg-bar\">\n          <div class=\"progress-fill blue\" style=\"width:${pilotPct}%\"></div>\n        </div>\n        <div class=\"seg-row\" style=\"margin-top:5px\">\n          <span class=\"seg-name\">Bestandskunden</span>\n          <span class=\"seg-vals\">${fmt(c.bestandArr || 0)}<span class=\"seg-count\">${fmtN(c.bestandOpps || 0)} Deals</span></span>\n        </div>\n        <div class=\"progress-track seg-bar\">\n          <div class=\"progress-fill amber\" style=\"width:${bestandPct}%\"></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Diese Woche</div>\n        <div class=\"wow-row\">\n          <div class=\"wow-item green\">↑ Neu<strong>+${fmt(cWow.newArr||0)}</strong><span>${fmtN(cWow.newOpps||0)} Deals</span></div>\n          <div class=\"wow-item green\">✓ Won<strong>+${fmt(cWow.wonCWArr||0)}</strong><span>${fmtN(cWow.wonCW||0)} Deals</span></div>\n          <div class=\"wow-item red\">✗ Lost<strong>−${fmt(cWow.lostCWArr||0)}</strong><span>${fmtN(cWow.lostCW||0)} Deals</span></div>\n        </div>\n      </div>`;\n\n        // ── Card 3: Win Rate (excl. Self-Service) ────────────────────────────\n    const wrVal      = w.value || 0;\n    const wrColor    = w.status || 'neutral';\n    const wrFill     = clamp(wrVal, 0, 100);\n    const wrDemos    = w.demos || 0;\n    const wrD2O      = w.demoToOpp || 0;\n    const wrD2OFill  = clamp(wrD2O, 0, 100);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Win Rate (Rep-driven)</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(wrVal)}</div>\n          <div class=\"badge ${wrColor}\">${statusLabel(wrColor)}</div>\n        </div>\n        <div class=\"progress-wrap\">\n          <div class=\"progress-labels\"><span>0%</span><span>Ziel: 30%</span></div>\n          <div class=\"progress-track\">\n            <div class=\"progress-fill ${wrColor}\" style=\"width:${wrFill}%\"></div>\n          </div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">✓ Gewonnen</span><span class=\"sub-value green\">${fmtN(w.wonCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">✗ Verloren</span><span class=\"sub-value red\">${fmtN(w.lostCount)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Gesamt (90d, excl. SS)</span><span class=\"sub-value\">${fmtN((w.wonCount||0)+(w.lostCount||0))}</span></div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"section-label\">Demo → Opp</div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Demos</span><span class=\"sub-value\">${fmtN(wrDemos)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Opps erstellt</span><span class=\"sub-value\">${fmtN(w.oppCreated||0)}</span></div>\n          <div class=\"sub-row\"><span class=\"sub-label\">Conversion</span><span class=\"sub-value blue\">${pct(wrD2O)}</span></div>\n        </div>\n        <div class=\"progress-track\" style=\"height:5px\">\n          <div class=\"progress-fill blue\" style=\"width:${wrD2OFill}%\"></div>\n        </div>\n      </div>`;\n\n    // ── Card 4: Aktivität (WoW) ───────────────────────────────────────────\n    const qtConv = a.qtConv || 0;\n    const cwA    = a.cw || {};\n    const pwA    = a.pw || {};\n\n    function wowArrow(cw, pw) {\n      if (!pw || pw === 0) return { arrow: '→', cls: 'neutral' };\n      const delta = ((cw - pw) / pw) * 100;\n      if (delta > 3)  return { arrow: '↑', cls: 'green' };\n      if (delta < -3) return { arrow: '↓', cls: 'red' };\n      return { arrow: '→', cls: 'neutral' };\n    }\n\n    const dialWoW  = wowArrow(cwA.dials     || 0, pwA.dials     || 0);\n    const qcWoW    = wowArrow(cwA.qualCalls || 0, pwA.qualCalls || 0);\n    const mtgWoW   = wowArrow(cwA.meetings  || 0, pwA.meetings  || 0);\n    const emailWoW = wowArrow(cwA.emails    || 0, pwA.emails    || 0);\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Aktivität</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(qtConv)}</div>\n          <div class=\"badge blue\">QT→Opp</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Anwahlen/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.dials || 0)} <span class=\"wow ${dialWoW.cls}\">${dialWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Qual.Calls/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.qualCalls || 0)} <span class=\"wow ${qcWoW.cls}\">${qcWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Meetings/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.meetings || 0)} <span class=\"wow ${mtgWoW.cls}\">${mtgWoW.arrow}</span></span>\n          </div>\n          <div class=\"sub-row\">\n            <span class=\"sub-label\">Mails/W</span>\n            <span class=\"sub-value\">${fmtN(cwA.emails || 0)} <span class=\"wow ${emailWoW.cls}\">${emailWoW.arrow}</span></span>\n          </div>\n        </div>\n      </div>`;\n\n    // ── Card 5: Stale Pipeline ────────────────────────────────────────────\n    const stColor = st.status || 'neutral';\n    const buckets = { '14-21d': 0, '21-30d': 0, '30d+': 0 };\n    (st.list || []).forEach(o => {\n      if (o.daysSinceActivity >= 30)      buckets['30d+']++;\n      else if (o.daysSinceActivity >= 21) buckets['21-30d']++;\n      else                                buckets['14-21d']++;\n    });\n\n    container.innerHTML += `\n      <div class=\"card\">\n        <div class=\"card-label\">Stale Pipeline</div>\n        <div class=\"card-main\">\n          <div class=\"card-value\">${pct(st.value)}</div>\n          <div class=\"badge ${stColor}\">${statusLabel(stColor)}</div>\n        </div>\n        <div class=\"divider\"></div>\n        <div class=\"sub-metrics\">\n          <div class=\"sub-row\"><span class=\"sub-label\">Stale Opps</span><span class=\"sub-value ${stColor}\">${fmtN(st.staleCount)} von ${fmtN(st.totalOpen)}</span></div>\n        </div>\n        <div class=\"buckets\">\n          <div class=\"bucket b1\"><div class=\"bucket-val\">${buckets['14-21d']}</div><div class=\"bucket-label\">14–21d</div></div>\n          <div class=\"bucket b2\"><div class=\"bucket-val\">${buckets['21-30d']}</div><div class=\"bucket-label\">21–30d</div></div>\n          <div class=\"bucket b3\"><div class=\"bucket-val\">${buckets['30d+']}</div><div class=\"bucket-label\">30d+</div></div>\n        </div>\n      </div>`;\n  }\n\n  // Bootstrap\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = JSON.stringify([appsmith.model.bookings, appsmith.model.composite]);\n      if (key !== _lastKey) { _lastKey = key; render(appsmith.model); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(appsmith.model || {}); poll(); });\n    appsmith.onModelChange((m) => render(m || {}));\n  } else {\n    render({});\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof render === 'function') { render(appsmith.model || {}); } if (typeof poll === 'function') { poll(); } });"
  },
