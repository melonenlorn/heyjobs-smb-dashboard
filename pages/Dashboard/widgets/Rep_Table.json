    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-header:  rgba(0,0,0,0.03);\n    --bg-hover:   rgba(0,0,0,0.03);\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body { background: transparent; font-family: var(--font); color: var(--text-1); padding: 4px; }\n\n  .container {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 12px;\n  }\n\n  thead tr {\n    background: var(--bg-header);\n    border-bottom: 1px solid var(--border);\n  }\n\n  th {\n    padding: 8px 10px;\n    text-align: right;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .05em;\n    text-transform: uppercase;\n    color: var(--text-3);\n    white-space: nowrap;\n  }\n  th:first-child { text-align: left; }\n  th.center      { text-align: center; }\n\n  tbody tr {\n    border-bottom: 1px solid var(--border);\n    transition: background .12s;\n  }\n  tbody tr:last-child { border-bottom: none; }\n  tbody tr:hover { background: var(--bg-hover); }\n\n  td {\n    padding: 8px 10px;\n    text-align: right;\n    color: var(--text-2);\n    font-weight: 700;\n    white-space: nowrap;\n  }\n  td:first-child { text-align: left; }\n  td.center      { text-align: center; }\n\n  .rep-cell { display: flex; flex-direction: column; gap: 2px; }\n  .rep-name  { font-size: 12px; font-weight: 800; color: var(--text-1); }\n  .rep-tags  { display: flex; gap: 4px; }\n\n  .tag {\n    font-size: 9px;\n    font-weight: 700;\n    padding: 1px 6px;\n    border-radius: 20px;\n    background: rgba(0,0,0,0.05);\n    color: var(--text-3);\n    letter-spacing: .04em;\n    white-space: nowrap;\n  }\n  .tag.team-ferdinand { background: rgba(0,120,212,0.10); color: var(--blue); }\n  .tag.team-jan       { background: rgba(201,120,0,0.10); color: var(--amber); }\n  .tag.team-philipp   { background: rgba(46,158,0,0.10);  color: var(--green); }\n\n  .badge {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 800;\n    padding: 2px 8px;\n    border-radius: 20px;\n    white-space: nowrap;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(0,0,0,0.05); color: var(--text-3); }\n\n  .risk-label {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 6px;\n    white-space: nowrap;\n  }\n  .risk-label.sev-3 { background: var(--red-bg);   color: var(--red);   }\n  .risk-label.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .risk-label.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .risk-label.sev-0 { color: var(--text-3); }\n\n  .num-red   { color: var(--red);   }\n  .num-amber { color: var(--amber); }\n  .num-green { color: var(--green); }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n</style>\n</head>\n<body>\n<div class=\"container\" id=\"container\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function fmt(n) {\n    if (!n) return '—';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n    if (abs >= 1000)    return Math.round(abs/1000) + 'k';\n    return abs.toString();\n  }\n  function fmtN(n) { return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.'); }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n\n  function teamClass(team) {\n    return { ferdinand: 'team-ferdinand', jan: 'team-jan', philipp: 'team-philipp' }[team] || '';\n  }\n  function teamLabel(team) {\n    return { ferdinand: 'Ferdinand', jan: 'Jan', philipp: 'Philipp' }[team] || (team || '—');\n  }\n  function levelLabel(level) {\n    return { '3': 'L3', '2': 'L2', '1': 'L1', 'rampup': 'Ramp' }[level] || 'L2';\n  }\n  function statusColor(v, thresholds, inverted) {\n    if (inverted) {\n      if (v <= thresholds[0]) return 'num-green';\n      if (v <= thresholds[1]) return 'num-amber';\n      return 'num-red';\n    }\n    if (v >= thresholds[0]) return 'num-green';\n    if (v >= thresholds[1]) return 'num-amber';\n    return 'num-red';\n  }\n\n  function render(model) {\n    const reps = model.reps || [];\n    const weeksElapsed = Math.max(1, model.weeksElapsed || 1);\n    const c = document.getElementById('container');\n\n    if (!reps.length) {\n      c.innerHTML = '<div class=\"empty\">Keine Daten</div>';\n      return;\n    }\n\n    const rows = reps.map(r => {\n      const diag    = r.rootCause || { cause: '—', severity: 0 };\n      const diagCls = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : 'sev-0';\n      const qualTotal = (r.qualCalls || 0) + (r.meetings || 0);\n      const anwW    = Math.round((r.dials || 0) / weeksElapsed);\n      const mailW   = Math.round((r.emails || 0) / weeksElapsed);\n      const cr      = (r.dials || 0) > 0 ? Math.round((qualTotal / r.dials) * 100) : 0;\n      const bkARR   = r.bookingsARR || 0;\n      const rr      = r.bookingsTarget > 0 ? Math.round((r.forecast / r.bookingsTarget) * 100) : 0;\n      const ta      = r.composite != null ? r.composite : 0;\n      const pilots  = r.pilotenTarget > 0 ? `${r.closedPilots || 0}/${r.pilotenTarget}` : `${r.closedPilots || 0}`;\n      const pilotsColor = r.pilotenTarget > 0\n        ? ((r.closedPilots || 0) >= r.pilotenTarget ? 'num-green' : (r.closedPilots || 0) >= r.pilotenTarget * 0.6 ? 'num-amber' : 'num-red')\n        : '';\n\n      return `\n        <tr>\n          <td>\n            <div class=\"rep-cell\">\n              <div class=\"rep-name\">${r.repName || '—'}</div>\n              <div class=\"rep-tags\">\n                <span class=\"tag\">${levelLabel(r.level)}</span>\n                <span class=\"tag ${teamClass(r.team)}\">${teamLabel(r.team)}</span>\n              </div>\n            </div>\n          </td>\n          <td>${fmtN(anwW)}</td>\n          <td>${fmtN(mailW)}</td>\n          <td class=\"${statusColor(qualTotal, [30, 20])}\">${fmtN(qualTotal)}</td>\n          <td class=\"${statusColor(cr, [20, 12])}\">${pct(cr)}</td>\n          <td>${fmtN(r.meetings || 0)}</td>\n          <td>${fmtN(r.openOpps || 0)}</td>\n          <td class=\"${statusColor(r.coverageVal || 0, [2.5, 1.5])}\">${(r.coverageVal || 0).toFixed(1).replace('.',',')}x</td>\n          <td class=\"${pilotsColor}\">${pilots}</td>\n          <td>${fmt(bkARR)}</td>\n          <td><span class=\"badge ${r.overallStatus || 'neutral'}\">${pct(ta)}</span></td>\n          <td class=\"${statusColor(rr, [80, 60])}\">${pct(rr)}</td>\n          <td><span class=\"risk-label ${diagCls}\">${diag.cause}</span></td>\n        </tr>`;\n    }).join('');\n\n    c.innerHTML = `\n      <table>\n        <thead>\n          <tr>\n            <th>Rep</th>\n            <th>Anw/W</th>\n            <th>Mails/W</th>\n            <th>QC</th>\n            <th>CR%</th>\n            <th>Meetings</th>\n            <th>Opps</th>\n            <th>Cov</th>\n            <th>Pilots</th>\n            <th>Bookings</th>\n            <th class=\"center\">TA%</th>\n            <th>RR%</th>\n            <th>Risk</th>\n          </tr>\n        </thead>\n        <tbody>${rows}</tbody>\n      </table>`;\n  }\n\n  function extract(m) {\n    if (!m) return { reps: [], weeksElapsed: 1 };\n    return {\n      reps:         Array.isArray(m) ? m : (m.reps || []),\n      weeksElapsed: m.weeksElapsed || 1,\n    };\n  }\n\n  // Key: total bookingsTarget (quota) — 0 before Q_Quotas loads, non-zero after\n  function modelKey(m) {\n    return (m && m.reps || []).reduce(function(s,r){ return s+(r.bookingsTarget||0); }, 0);\n  }\n\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = modelKey(appsmith.model);\n      if (key !== _lastKey) { _lastKey = key; render(extract(appsmith.model)); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(extract(appsmith.model)); poll(); });\n    appsmith.onModelChange((m) => render(extract(m)));\n  } else {\n    render({ reps: [], weeksElapsed: 1 });\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
