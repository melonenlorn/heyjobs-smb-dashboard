{
  "backgroundColor": "#FFFFFF",
  "borderColor": "#E0DEDE",
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "borderWidth": "1",
  "bottomRow": 132,
  "boxShadow": "{{appsmith.theme.boxShadow.appBoxShadow}}",
  "defaultModel": "{{(function(){var _=[Q_Bookings_QTD.data,Q_SelfService_QTD.data,Q_Pipeline_Open.data,Q_Pilots_Open.data,Q_Stale_Pipeline.data,Q_WinLoss.data,Q_Calls_QTD.data,Q_QualCalls_QTD.data,Q_Emails_QTD.data,Q_Meetings_QTD.data,Q_Quotas.data,Q_Users_Team.data,Q_Opps_Created_QTD.data,Q_Demos_QTD.data,Q_Calls_CW.data,Q_Calls_PW.data,Q_QualCalls_CW.data,Q_QualCalls_PW.data,Q_Emails_CW.data,Q_Emails_PW.data,Q_Meetings_CW.data,Q_Meetings_PW.data];return {reps: JS_Data.dashboardReps(), weeksElapsed: Math.max(1, Math.round(JS_Config.getQuarterProgress() * 13))};})()}}",
  "dynamicBindingPathList": [
    {
      "key": "theme"
    },
    {
      "key": "borderRadius"
    },
    {
      "key": "boxShadow"
    },
    {
      "key": "defaultModel"
    }
  ],
  "dynamicHeight": "FIXED",
  "dynamicTriggerPathList": [
    {
      "key": "onResetClick"
    }
  ],
  "events": [
    "onResetClick"
  ],
  "isCanvas": false,
  "isLoading": false,
  "isSearchWildcard": true,
  "isVisible": true,
  "key": "rep_table_key1",
  "leftColumn": 0,
  "maxDynamicHeight": 9000,
  "minDynamicHeight": 4,
  "mobileBottomRow": 90,
  "mobileLeftColumn": 0,
  "mobileRightColumn": 12,
  "mobileTopRow": 56,
  "needsErrorInfo": false,
  "onResetClick": "{{showAlert('Successfully reset!!', '');}}",
  "parentColumnSpace": 13.1875,
  "parentId": "0",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "rightColumn": 64,
  "srcDoc": {
    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-header:  rgba(0,0,0,0.03);\n    --bg-hover:   rgba(0,0,0,0.03);\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body { background: transparent; font-family: var(--font); color: var(--text-1); padding: 4px; position: relative; }\n\n  .container {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 12px;\n  }\n\n  thead tr {\n    background: var(--bg-header);\n    border-bottom: 1px solid var(--border);\n  }\n\n  th {\n    padding: 8px 10px;\n    text-align: right;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .05em;\n    text-transform: uppercase;\n    color: var(--text-3);\n    white-space: nowrap;\n  }\n  th:first-child { text-align: left; }\n  th.center      { text-align: center; }\n  th.group-touch { border-left: 2px solid rgba(0,120,212,0.15); }\n  th.group-qt    { border-left: 2px solid rgba(46,158,0,0.15); }\n  th.group-conv  { border-left: 2px solid rgba(201,120,0,0.15); }\n  th.group-result{ border-left: 2px solid rgba(0,0,0,0.08); }\n\n  tbody tr {\n    border-bottom: 1px solid var(--border);\n    transition: background .12s;\n    cursor: pointer;\n  }\n  tbody tr:last-child { border-bottom: none; }\n  tbody tr:hover { background: var(--bg-hover); }\n\n  td {\n    padding: 8px 10px;\n    text-align: right;\n    color: var(--text-2);\n    font-weight: 700;\n    white-space: nowrap;\n  }\n  td:first-child { text-align: left; }\n  td.center      { text-align: center; }\n  td.group-touch { border-left: 2px solid rgba(0,120,212,0.10); }\n  td.group-qt    { border-left: 2px solid rgba(46,158,0,0.10); }\n  td.group-conv  { border-left: 2px solid rgba(201,120,0,0.10); }\n  td.group-result{ border-left: 2px solid rgba(0,0,0,0.05); }\n\n  .rep-cell { display: flex; flex-direction: column; gap: 2px; }\n  .rep-name  { font-size: 12px; font-weight: 800; color: var(--text-1); }\n  .rep-tags  { display: flex; gap: 4px; }\n\n  .tag {\n    font-size: 9px;\n    font-weight: 700;\n    padding: 1px 6px;\n    border-radius: 20px;\n    background: rgba(0,0,0,0.05);\n    color: var(--text-3);\n    letter-spacing: .04em;\n    white-space: nowrap;\n  }\n  .tag.team-ferdinand { background: rgba(0,120,212,0.10); color: var(--blue); }\n  .tag.team-jan       { background: rgba(201,120,0,0.10); color: var(--amber); }\n  .tag.team-philipp   { background: rgba(46,158,0,0.10);  color: var(--green); }\n\n  .badge {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 800;\n    padding: 2px 8px;\n    border-radius: 20px;\n    white-space: nowrap;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(0,0,0,0.05); color: var(--text-3); }\n\n  .risk-label {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 6px;\n    white-space: nowrap;\n  }\n  .risk-label.sev-3 { background: var(--red-bg);   color: var(--red);   }\n  .risk-label.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .risk-label.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .risk-label.sev-0 { color: var(--text-3); }\n\n  .num-red   { color: var(--red);   }\n  .num-amber { color: var(--amber); }\n  .num-green { color: var(--green); }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n\n  /* ── Modal ── */\n  .modal-overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.45);\n    z-index: 1000;\n    align-items: center;\n    justify-content: center;\n  }\n  .modal-overlay.open { display: flex; }\n\n  .modal {\n    background: #fff;\n    border-radius: var(--radius);\n    box-shadow: 0 8px 32px rgba(0,0,0,0.18);\n    padding: 24px;\n    width: 440px;\n    max-width: 96vw;\n    max-height: 90vh;\n    overflow-y: auto;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n\n  .modal-header {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 12px;\n  }\n  .modal-name { font-size: 18px; font-weight: 900; color: var(--text-1); }\n  .modal-meta { display: flex; gap: 6px; margin-top: 5px; }\n  .modal-close {\n    background: none;\n    border: none;\n    font-size: 20px;\n    cursor: pointer;\n    color: var(--text-3);\n    line-height: 1;\n    padding: 2px 4px;\n  }\n  .modal-close:hover { color: var(--text-1); }\n\n  .modal-divider { height: 1px; background: var(--border); }\n\n  .modal-score-row {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .modal-score-val {\n    font-size: 42px;\n    font-weight: 900;\n    line-height: 1;\n    min-width: 72px;\n  }\n  .modal-score-val.red    { color: var(--red); }\n  .modal-score-val.amber  { color: var(--amber); }\n  .modal-score-val.green  { color: var(--green); }\n  .modal-score-val.neutral{ color: var(--text-3); }\n\n  .modal-progress-group { flex: 1; display: flex; flex-direction: column; gap: 5px; }\n  .modal-progress-label {\n    display: flex;\n    justify-content: space-between;\n    font-size: 11px;\n    color: var(--text-3);\n  }\n  .modal-progress-label span:last-child { color: var(--text-2); font-weight: 700; }\n  .progress-track {\n    height: 5px;\n    background: rgba(0,0,0,0.07);\n    border-radius: 99px;\n    overflow: hidden;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n  }\n  .progress-fill.red    { background: var(--red); }\n  .progress-fill.amber  { background: var(--amber); }\n  .progress-fill.green  { background: var(--green); }\n\n  .modal-kpi-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 8px 12px;\n  }\n  .modal-kpi-cell { display: flex; flex-direction: column; gap: 2px; }\n  .modal-kpi-label { font-size: 10px; color: var(--text-3); font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }\n  .modal-kpi-value { font-size: 16px; font-weight: 800; }\n  .modal-kpi-value.red    { color: var(--red); }\n  .modal-kpi-value.amber  { color: var(--amber); }\n  .modal-kpi-value.green  { color: var(--green); }\n  .modal-kpi-value.neutral{ color: var(--text-2); }\n\n  .modal-section-title {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n    margin-bottom: 6px;\n  }\n\n  .modal-act-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 6px;\n  }\n  .modal-act-cell {\n    background: rgba(0,0,0,0.04);\n    border-radius: 8px;\n    padding: 6px 4px;\n    text-align: center;\n  }\n  .modal-act-val   { font-size: 16px; font-weight: 800; color: var(--text-2); }\n  .modal-act-label { font-size: 9px; color: var(--text-3); margin-top: 2px; text-transform: uppercase; letter-spacing: .04em; }\n\n  .modal-diagnosis {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 12px;\n    font-weight: 700;\n    padding: 8px 12px;\n    border-radius: 8px;\n    background: rgba(0,0,0,0.04);\n    color: var(--text-3);\n  }\n  .modal-diagnosis.sev-3 { background: var(--red-bg);   color: var(--red); }\n  .modal-diagnosis.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .modal-diagnosis.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .modal-diagnosis::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }\n</style>\n</head>\n<body>\n\n<div class=\"container\" id=\"container\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<div class=\"modal-overlay\" id=\"modal-overlay\" onclick=\"closeModal(event)\">\n  <div class=\"modal\" id=\"modal-content\" onclick=\"event.stopPropagation()\"></div>\n</div>\n\n<script>\n  var _allReps = [];\n\n  function fmt(n) {\n    if (!n) return '—';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n    if (abs >= 1000)    return Math.round(abs/1000) + 'k';\n    return abs.toString();\n  }\n  function fmtN(n) { return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.'); }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function teamClass(team) {\n    return { ferdinand: 'team-ferdinand', jan: 'team-jan', philipp: 'team-philipp' }[team] || '';\n  }\n  function teamLabel(team) {\n    return { ferdinand: 'Ferdinand', jan: 'Jan', philipp: 'Philipp' }[team] || (team || '—');\n  }\n  function levelLabel(level) {\n    return { '3': 'L3', '2': 'L2', '1': 'L1', 'rampup': 'Ramp' }[level] || 'L2';\n  }\n  function statusColor(v, thresholds, inverted) {\n    if (inverted) {\n      if (v <= thresholds[0]) return 'num-green';\n      if (v <= thresholds[1]) return 'num-amber';\n      return 'num-red';\n    }\n    if (v >= thresholds[0]) return 'num-green';\n    if (v >= thresholds[1]) return 'num-amber';\n    return 'num-red';\n  }\n\n  function openModal(repId) {\n    const r = _allReps.find(x => x.id === repId);\n    if (!r) return;\n    const status     = r.overallStatus || 'neutral';\n    const composite  = r.composite != null ? r.composite : 0;\n    const bAtt       = r.bookingsAtt || 0;\n    const pAtt       = r.pilotenAtt  || 0;\n    const pW         = r.pilotenWeight != null ? r.pilotenWeight : 0;\n    const qualTotal  = (r.qualCalls || 0) + (r.meetings || 0);\n    const cr         = (r.dials || 0) > 0 ? Math.round((qualTotal / r.dials) * 100) : 0;\n    const convPct    = qualTotal > 0 ? Math.round(((r.oppCreated || 0) / qualTotal) * 100) : 0;\n    const demoPct    = (r.meetings || 0) > 0 ? Math.round(((r.demos || 0) / r.meetings) * 100) : 0;\n    const diag       = r.rootCause || { cause: '—', severity: 0 };\n    const diagCls    = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : '';\n    const bFill      = clamp(bAtt, 0, 100);\n    const bClr       = bAtt >= 80 ? 'green' : bAtt >= 60 ? 'amber' : 'red';\n    const pFill      = clamp(pAtt, 0, 100);\n    const pClr       = pAtt >= 80 ? 'green' : pAtt >= 60 ? 'amber' : 'red';\n\n    document.getElementById('modal-content').innerHTML = `\n      <div class=\"modal-header\">\n        <div>\n          <div class=\"modal-name\">${r.repName || '—'}</div>\n          <div class=\"modal-meta\">\n            <span class=\"tag\">${levelLabel(r.level)}</span>\n            <span class=\"tag ${teamClass(r.team)}\">${teamLabel(r.team)}</span>\n          </div>\n        </div>\n        <button class=\"modal-close\" onclick=\"closeModal()\">✕</button>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div class=\"modal-score-row\">\n        <div class=\"modal-score-val ${status}\">${pct(composite)}</div>\n        <div class=\"modal-progress-group\">\n          <div class=\"modal-progress-label\"><span>Bookings (${Math.round((r.bookingsWeight||0.5)*100)}%)</span><span>${pct(bAtt)}</span></div>\n          <div class=\"progress-track\"><div class=\"progress-fill ${bClr}\" style=\"width:${bFill}%\"></div></div>\n          ${pW > 0 ? `\n          <div class=\"modal-progress-label\" style=\"margin-top:4px\"><span>Piloten (${Math.round((pW||0.5)*100)}%)</span><span>${pct(pAtt)}</span></div>\n          <div class=\"progress-track\"><div class=\"progress-fill ${pClr}\" style=\"width:${pFill}%\"></div></div>\n          ` : ''}\n        </div>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div class=\"modal-kpi-grid\">\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Coverage</span>\n          <span class=\"modal-kpi-value ${r.coverageStatus || 'neutral'}\">${(r.coverageVal || 0).toFixed(1).replace('.',',')}x</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Win Rate</span>\n          <span class=\"modal-kpi-value ${r.winRateStatus || 'neutral'}\">${pct(r.winRateVal || 0)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Stale</span>\n          <span class=\"modal-kpi-value ${r.staleRateStatus || 'neutral'}\">${pct(r.staleRateVal || 0)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Forecast</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.forecast)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Bookings</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.bookingsARR)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Quota</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.bookingsTarget)}</span>\n        </div>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div>\n        <div class=\"modal-section-title\">Aktivität (QTD)</div>\n        <div class=\"modal-act-grid\">\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.dials || 0)}</div><div class=\"modal-act-label\">Anwahlen</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.qualCalls || 0)}</div><div class=\"modal-act-label\">Qual. Calls</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.meetings || 0)}</div><div class=\"modal-act-label\">Meetings</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.emails || 0)}</div><div class=\"modal-act-label\">E-Mails</div></div>\n        </div>\n        <div style=\"display:flex;gap:16px;margin-top:8px;font-size:12px;\">\n          <span style=\"color:var(--text-3)\">CR Anwahl→QT: <strong style=\"color:var(--text-2)\">${pct(cr)}</strong></span>\n          <span style=\"color:var(--text-3)\">QT→Opp Conv: <strong style=\"color:var(--text-2)\">${pct(convPct)}</strong></span>\n          <span style=\"color:var(--text-3)\">Demo-Anteil: <strong style=\"color:var(--text-2)\">${pct(demoPct)}</strong></span>\n        </div>\n      </div>\n\n      <div class=\"modal-diagnosis ${diagCls}\">${diag.cause}</div>`;\n\n    document.getElementById('modal-overlay').classList.add('open');\n  }\n\n  function closeModal(e) {\n    if (!e || e.target === document.getElementById('modal-overlay')) {\n      document.getElementById('modal-overlay').classList.remove('open');\n    }\n  }\n\n  function render(model) {\n    const reps = model.reps || [];\n    const weeksElapsed = Math.max(1, model.weeksElapsed || 1);\n    const c = document.getElementById('container');\n    _allReps = reps;\n\n    if (!reps.length) {\n      c.innerHTML = '<div class=\"empty\">Keine Daten</div>';\n      return;\n    }\n\n    const rows = reps.map(r => {\n      const diag     = r.rootCause || { cause: '—', severity: 0 };\n      const diagCls  = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : 'sev-0';\n      const qualTotal = (r.qualCalls || 0) + (r.meetings || 0);\n      const touchW   = Math.round(((r.dials || 0) + (r.emails || 0)) / weeksElapsed);\n      const callsW   = Math.round((r.dials || 0) / weeksElapsed);\n      const mailsW   = Math.round((r.emails || 0) / weeksElapsed);\n      const crPct    = (r.dials || 0) > 0 ? Math.round((qualTotal / r.dials) * 100) : 0;\n      const convPct  = qualTotal > 0 ? Math.round(((r.oppCreated || 0) / qualTotal) * 100) : 0;\n      const bkARR    = r.bookingsARR || 0;\n      const ta       = r.composite != null ? r.composite : 0;\n      const pilots   = r.pilotenTarget > 0 ? `${r.closedPilots || 0}/${r.pilotenTarget}` : `${r.closedPilots || 0}`;\n      const pilotsColor = r.pilotenTarget > 0\n        ? ((r.closedPilots || 0) >= r.pilotenTarget ? 'num-green' : (r.closedPilots || 0) >= r.pilotenTarget * 0.6 ? 'num-amber' : 'num-red')\n        : '';\n\n      return `\n        <tr onclick=\"openModal('${r.id}')\">\n          <td>\n            <div class=\"rep-cell\">\n              <div class=\"rep-name\">${r.repName || '—'}</div>\n              <div class=\"rep-tags\">\n                <span class=\"tag\">${levelLabel(r.level)}</span>\n                <span class=\"tag ${teamClass(r.team)}\">${teamLabel(r.team)}</span>\n              </div>\n            </div>\n          </td>\n          <td class=\"group-touch\">${fmtN(touchW)}</td>\n          <td>${fmtN(callsW)}</td>\n          <td>${fmtN(mailsW)}</td>\n          <td class=\"group-qt ${statusColor(qualTotal, [30, 20])}\">${fmtN(qualTotal)}</td>\n          <td class=\"${statusColor(crPct, [20, 12])}\">${pct(crPct)}</td>\n          <td>${fmtN(r.qualCalls || 0)}</td>\n          <td>${fmtN(r.meetings || 0)}</td>\n          <td class=\"group-conv\">${fmtN(r.oppCreated || 0)}</td>\n          <td class=\"${statusColor(convPct, [20, 10])}\">${pct(convPct)}</td>\n          <td class=\"group-result ${pilotsColor}\">${pilots}</td>\n          <td>${fmt(bkARR)}</td>\n          <td class=\"${statusColor(r.coverageVal || 0, [2.5, 1.5])}\">${(r.coverageVal || 0).toFixed(1).replace('.',',')}x</td>\n          <td><span class=\"badge ${r.overallStatus || 'neutral'}\">${pct(ta)}</span></td>\n          <td><span class=\"risk-label ${diagCls}\">${diag.cause}</span></td>\n        </tr>`;\n    }).join('');\n\n    c.innerHTML = `\n      <table>\n        <thead>\n          <tr>\n            <th>Rep</th>\n            <th class=\"group-touch\">Touch/W</th>\n            <th>Calls/W</th>\n            <th>Mails/W</th>\n            <th class=\"group-qt\">QT</th>\n            <th>CR%</th>\n            <th>QC</th>\n            <th>Meetings</th>\n            <th class=\"group-conv\">Opps</th>\n            <th>Conv%</th>\n            <th class=\"group-result\">Pilots</th>\n            <th>Bookings</th>\n            <th>Cov</th>\n            <th class=\"center\">TA%</th>\n            <th>Risk</th>\n          </tr>\n        </thead>\n        <tbody>${rows}</tbody>\n      </table>`;\n  }\n\n  function extract(m) {\n    if (!m) return { reps: [], weeksElapsed: 1 };\n    return {\n      reps:         Array.isArray(m) ? m : (m.reps || []),\n      weeksElapsed: m.weeksElapsed || 1,\n    };\n  }\n\n  // Key: total bookingsTarget (quota) — 0 before Q_Quotas loads, non-zero after\n  function modelKey(m) {\n    return (m && m.reps || []).reduce(function(s,r){ return s+(r.bookingsTarget||0); }, 0);\n  }\n\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = modelKey(appsmith.model);\n      if (key !== _lastKey) { _lastKey = key; render(extract(appsmith.model)); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(extract(appsmith.model)); poll(); });\n    appsmith.onModelChange((m) => render(extract(m)));\n  } else {\n    render({ reps: [], weeksElapsed: 1 });\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
  "theme": "{{appsmith.theme}}",
  "topRow": 56,
  "type": "CUSTOM_WIDGET",
  "uncompiledSrcDoc": {
    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-header:  rgba(0,0,0,0.03);\n    --bg-hover:   rgba(0,0,0,0.03);\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body { background: transparent; font-family: var(--font); color: var(--text-1); padding: 4px; position: relative; }\n\n  .container {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 12px;\n  }\n\n  thead tr {\n    background: var(--bg-header);\n    border-bottom: 1px solid var(--border);\n  }\n\n  th {\n    padding: 8px 10px;\n    text-align: right;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .05em;\n    text-transform: uppercase;\n    color: var(--text-3);\n    white-space: nowrap;\n  }\n  th:first-child { text-align: left; }\n  th.center      { text-align: center; }\n  th.group-touch { border-left: 2px solid rgba(0,120,212,0.15); }\n  th.group-qt    { border-left: 2px solid rgba(46,158,0,0.15); }\n  th.group-conv  { border-left: 2px solid rgba(201,120,0,0.15); }\n  th.group-result{ border-left: 2px solid rgba(0,0,0,0.08); }\n\n  tbody tr {\n    border-bottom: 1px solid var(--border);\n    transition: background .12s;\n    cursor: pointer;\n  }\n  tbody tr:last-child { border-bottom: none; }\n  tbody tr:hover { background: var(--bg-hover); }\n\n  td {\n    padding: 8px 10px;\n    text-align: right;\n    color: var(--text-2);\n    font-weight: 700;\n    white-space: nowrap;\n  }\n  td:first-child { text-align: left; }\n  td.center      { text-align: center; }\n  td.group-touch { border-left: 2px solid rgba(0,120,212,0.10); }\n  td.group-qt    { border-left: 2px solid rgba(46,158,0,0.10); }\n  td.group-conv  { border-left: 2px solid rgba(201,120,0,0.10); }\n  td.group-result{ border-left: 2px solid rgba(0,0,0,0.05); }\n\n  .rep-cell { display: flex; flex-direction: column; gap: 2px; }\n  .rep-name  { font-size: 12px; font-weight: 800; color: var(--text-1); }\n  .rep-tags  { display: flex; gap: 4px; }\n\n  .tag {\n    font-size: 9px;\n    font-weight: 700;\n    padding: 1px 6px;\n    border-radius: 20px;\n    background: rgba(0,0,0,0.05);\n    color: var(--text-3);\n    letter-spacing: .04em;\n    white-space: nowrap;\n  }\n  .tag.team-ferdinand { background: rgba(0,120,212,0.10); color: var(--blue); }\n  .tag.team-jan       { background: rgba(201,120,0,0.10); color: var(--amber); }\n  .tag.team-philipp   { background: rgba(46,158,0,0.10);  color: var(--green); }\n\n  .badge {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 800;\n    padding: 2px 8px;\n    border-radius: 20px;\n    white-space: nowrap;\n  }\n  .badge.green  { background: var(--green-bg);  color: var(--green);  }\n  .badge.amber  { background: var(--amber-bg);  color: var(--amber);  }\n  .badge.red    { background: var(--red-bg);    color: var(--red);    }\n  .badge.blue   { background: var(--blue-bg);   color: var(--blue);   }\n  .badge.neutral{ background: rgba(0,0,0,0.05); color: var(--text-3); }\n\n  .risk-label {\n    display: inline-block;\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 8px;\n    border-radius: 6px;\n    white-space: nowrap;\n  }\n  .risk-label.sev-3 { background: var(--red-bg);   color: var(--red);   }\n  .risk-label.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .risk-label.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .risk-label.sev-0 { color: var(--text-3); }\n\n  .num-red   { color: var(--red);   }\n  .num-amber { color: var(--amber); }\n  .num-green { color: var(--green); }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n\n  /* ── Modal ── */\n  .modal-overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.45);\n    z-index: 1000;\n    align-items: center;\n    justify-content: center;\n  }\n  .modal-overlay.open { display: flex; }\n\n  .modal {\n    background: #fff;\n    border-radius: var(--radius);\n    box-shadow: 0 8px 32px rgba(0,0,0,0.18);\n    padding: 24px;\n    width: 440px;\n    max-width: 96vw;\n    max-height: 90vh;\n    overflow-y: auto;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n  }\n\n  .modal-header {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 12px;\n  }\n  .modal-name { font-size: 18px; font-weight: 900; color: var(--text-1); }\n  .modal-meta { display: flex; gap: 6px; margin-top: 5px; }\n  .modal-close {\n    background: none;\n    border: none;\n    font-size: 20px;\n    cursor: pointer;\n    color: var(--text-3);\n    line-height: 1;\n    padding: 2px 4px;\n  }\n  .modal-close:hover { color: var(--text-1); }\n\n  .modal-divider { height: 1px; background: var(--border); }\n\n  .modal-score-row {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n  .modal-score-val {\n    font-size: 42px;\n    font-weight: 900;\n    line-height: 1;\n    min-width: 72px;\n  }\n  .modal-score-val.red    { color: var(--red); }\n  .modal-score-val.amber  { color: var(--amber); }\n  .modal-score-val.green  { color: var(--green); }\n  .modal-score-val.neutral{ color: var(--text-3); }\n\n  .modal-progress-group { flex: 1; display: flex; flex-direction: column; gap: 5px; }\n  .modal-progress-label {\n    display: flex;\n    justify-content: space-between;\n    font-size: 11px;\n    color: var(--text-3);\n  }\n  .modal-progress-label span:last-child { color: var(--text-2); font-weight: 700; }\n  .progress-track {\n    height: 5px;\n    background: rgba(0,0,0,0.07);\n    border-radius: 99px;\n    overflow: hidden;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n  }\n  .progress-fill.red    { background: var(--red); }\n  .progress-fill.amber  { background: var(--amber); }\n  .progress-fill.green  { background: var(--green); }\n\n  .modal-kpi-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr 1fr;\n    gap: 8px 12px;\n  }\n  .modal-kpi-cell { display: flex; flex-direction: column; gap: 2px; }\n  .modal-kpi-label { font-size: 10px; color: var(--text-3); font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }\n  .modal-kpi-value { font-size: 16px; font-weight: 800; }\n  .modal-kpi-value.red    { color: var(--red); }\n  .modal-kpi-value.amber  { color: var(--amber); }\n  .modal-kpi-value.green  { color: var(--green); }\n  .modal-kpi-value.neutral{ color: var(--text-2); }\n\n  .modal-section-title {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n    margin-bottom: 6px;\n  }\n\n  .modal-act-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 6px;\n  }\n  .modal-act-cell {\n    background: rgba(0,0,0,0.04);\n    border-radius: 8px;\n    padding: 6px 4px;\n    text-align: center;\n  }\n  .modal-act-val   { font-size: 16px; font-weight: 800; color: var(--text-2); }\n  .modal-act-label { font-size: 9px; color: var(--text-3); margin-top: 2px; text-transform: uppercase; letter-spacing: .04em; }\n\n  .modal-diagnosis {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 12px;\n    font-weight: 700;\n    padding: 8px 12px;\n    border-radius: 8px;\n    background: rgba(0,0,0,0.04);\n    color: var(--text-3);\n  }\n  .modal-diagnosis.sev-3 { background: var(--red-bg);   color: var(--red); }\n  .modal-diagnosis.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .modal-diagnosis.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .modal-diagnosis::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }\n</style>\n</head>\n<body>\n\n<div class=\"container\" id=\"container\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<div class=\"modal-overlay\" id=\"modal-overlay\" onclick=\"closeModal(event)\">\n  <div class=\"modal\" id=\"modal-content\" onclick=\"event.stopPropagation()\"></div>\n</div>\n\n<script>\n  var _allReps = [];\n\n  function fmt(n) {\n    if (!n) return '—';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n    if (abs >= 1000)    return Math.round(abs/1000) + 'k';\n    return abs.toString();\n  }\n  function fmtN(n) { return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.'); }\n  function pct(n) { return (n || 0) + '\\u202f%'; }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function teamClass(team) {\n    return { ferdinand: 'team-ferdinand', jan: 'team-jan', philipp: 'team-philipp' }[team] || '';\n  }\n  function teamLabel(team) {\n    return { ferdinand: 'Ferdinand', jan: 'Jan', philipp: 'Philipp' }[team] || (team || '—');\n  }\n  function levelLabel(level) {\n    return { '3': 'L3', '2': 'L2', '1': 'L1', 'rampup': 'Ramp' }[level] || 'L2';\n  }\n  function statusColor(v, thresholds, inverted) {\n    if (inverted) {\n      if (v <= thresholds[0]) return 'num-green';\n      if (v <= thresholds[1]) return 'num-amber';\n      return 'num-red';\n    }\n    if (v >= thresholds[0]) return 'num-green';\n    if (v >= thresholds[1]) return 'num-amber';\n    return 'num-red';\n  }\n\n  function openModal(repId) {\n    const r = _allReps.find(x => x.id === repId);\n    if (!r) return;\n    const status     = r.overallStatus || 'neutral';\n    const composite  = r.composite != null ? r.composite : 0;\n    const bAtt       = r.bookingsAtt || 0;\n    const pAtt       = r.pilotenAtt  || 0;\n    const pW         = r.pilotenWeight != null ? r.pilotenWeight : 0;\n    const qualTotal  = (r.qualCalls || 0) + (r.meetings || 0);\n    const cr         = (r.dials || 0) > 0 ? Math.round((qualTotal / r.dials) * 100) : 0;\n    const convPct    = qualTotal > 0 ? Math.round(((r.oppCreated || 0) / qualTotal) * 100) : 0;\n    const demoPct    = (r.meetings || 0) > 0 ? Math.round(((r.demos || 0) / r.meetings) * 100) : 0;\n    const diag       = r.rootCause || { cause: '—', severity: 0 };\n    const diagCls    = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : '';\n    const bFill      = clamp(bAtt, 0, 100);\n    const bClr       = bAtt >= 80 ? 'green' : bAtt >= 60 ? 'amber' : 'red';\n    const pFill      = clamp(pAtt, 0, 100);\n    const pClr       = pAtt >= 80 ? 'green' : pAtt >= 60 ? 'amber' : 'red';\n\n    document.getElementById('modal-content').innerHTML = `\n      <div class=\"modal-header\">\n        <div>\n          <div class=\"modal-name\">${r.repName || '—'}</div>\n          <div class=\"modal-meta\">\n            <span class=\"tag\">${levelLabel(r.level)}</span>\n            <span class=\"tag ${teamClass(r.team)}\">${teamLabel(r.team)}</span>\n          </div>\n        </div>\n        <button class=\"modal-close\" onclick=\"closeModal()\">✕</button>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div class=\"modal-score-row\">\n        <div class=\"modal-score-val ${status}\">${pct(composite)}</div>\n        <div class=\"modal-progress-group\">\n          <div class=\"modal-progress-label\"><span>Bookings (${Math.round((r.bookingsWeight||0.5)*100)}%)</span><span>${pct(bAtt)}</span></div>\n          <div class=\"progress-track\"><div class=\"progress-fill ${bClr}\" style=\"width:${bFill}%\"></div></div>\n          ${pW > 0 ? `\n          <div class=\"modal-progress-label\" style=\"margin-top:4px\"><span>Piloten (${Math.round((pW||0.5)*100)}%)</span><span>${pct(pAtt)}</span></div>\n          <div class=\"progress-track\"><div class=\"progress-fill ${pClr}\" style=\"width:${pFill}%\"></div></div>\n          ` : ''}\n        </div>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div class=\"modal-kpi-grid\">\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Coverage</span>\n          <span class=\"modal-kpi-value ${r.coverageStatus || 'neutral'}\">${(r.coverageVal || 0).toFixed(1).replace('.',',')}x</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Win Rate</span>\n          <span class=\"modal-kpi-value ${r.winRateStatus || 'neutral'}\">${pct(r.winRateVal || 0)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Stale</span>\n          <span class=\"modal-kpi-value ${r.staleRateStatus || 'neutral'}\">${pct(r.staleRateVal || 0)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Forecast</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.forecast)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Bookings</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.bookingsARR)}</span>\n        </div>\n        <div class=\"modal-kpi-cell\">\n          <span class=\"modal-kpi-label\">Quota</span>\n          <span class=\"modal-kpi-value neutral\">${fmt(r.bookingsTarget)}</span>\n        </div>\n      </div>\n\n      <div class=\"modal-divider\"></div>\n\n      <div>\n        <div class=\"modal-section-title\">Aktivität (QTD)</div>\n        <div class=\"modal-act-grid\">\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.dials || 0)}</div><div class=\"modal-act-label\">Anwahlen</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.qualCalls || 0)}</div><div class=\"modal-act-label\">Qual. Calls</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.meetings || 0)}</div><div class=\"modal-act-label\">Meetings</div></div>\n          <div class=\"modal-act-cell\"><div class=\"modal-act-val\">${fmtN(r.emails || 0)}</div><div class=\"modal-act-label\">E-Mails</div></div>\n        </div>\n        <div style=\"display:flex;gap:16px;margin-top:8px;font-size:12px;\">\n          <span style=\"color:var(--text-3)\">CR Anwahl→QT: <strong style=\"color:var(--text-2)\">${pct(cr)}</strong></span>\n          <span style=\"color:var(--text-3)\">QT→Opp Conv: <strong style=\"color:var(--text-2)\">${pct(convPct)}</strong></span>\n          <span style=\"color:var(--text-3)\">Demo-Anteil: <strong style=\"color:var(--text-2)\">${pct(demoPct)}</strong></span>\n        </div>\n      </div>\n\n      <div class=\"modal-diagnosis ${diagCls}\">${diag.cause}</div>`;\n\n    document.getElementById('modal-overlay').classList.add('open');\n  }\n\n  function closeModal(e) {\n    if (!e || e.target === document.getElementById('modal-overlay')) {\n      document.getElementById('modal-overlay').classList.remove('open');\n    }\n  }\n\n  function render(model) {\n    const reps = model.reps || [];\n    const weeksElapsed = Math.max(1, model.weeksElapsed || 1);\n    const c = document.getElementById('container');\n    _allReps = reps;\n\n    if (!reps.length) {\n      c.innerHTML = '<div class=\"empty\">Keine Daten</div>';\n      return;\n    }\n\n    const rows = reps.map(r => {\n      const diag     = r.rootCause || { cause: '—', severity: 0 };\n      const diagCls  = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : 'sev-0';\n      const qualTotal = (r.qualCalls || 0) + (r.meetings || 0);\n      const touchW   = Math.round(((r.dials || 0) + (r.emails || 0)) / weeksElapsed);\n      const callsW   = Math.round((r.dials || 0) / weeksElapsed);\n      const mailsW   = Math.round((r.emails || 0) / weeksElapsed);\n      const crPct    = (r.dials || 0) > 0 ? Math.round((qualTotal / r.dials) * 100) : 0;\n      const convPct  = qualTotal > 0 ? Math.round(((r.oppCreated || 0) / qualTotal) * 100) : 0;\n      const bkARR    = r.bookingsARR || 0;\n      const ta       = r.composite != null ? r.composite : 0;\n      const pilots   = r.pilotenTarget > 0 ? `${r.closedPilots || 0}/${r.pilotenTarget}` : `${r.closedPilots || 0}`;\n      const pilotsColor = r.pilotenTarget > 0\n        ? ((r.closedPilots || 0) >= r.pilotenTarget ? 'num-green' : (r.closedPilots || 0) >= r.pilotenTarget * 0.6 ? 'num-amber' : 'num-red')\n        : '';\n\n      return `\n        <tr onclick=\"openModal('${r.id}')\">\n          <td>\n            <div class=\"rep-cell\">\n              <div class=\"rep-name\">${r.repName || '—'}</div>\n              <div class=\"rep-tags\">\n                <span class=\"tag\">${levelLabel(r.level)}</span>\n                <span class=\"tag ${teamClass(r.team)}\">${teamLabel(r.team)}</span>\n              </div>\n            </div>\n          </td>\n          <td class=\"group-touch\">${fmtN(touchW)}</td>\n          <td>${fmtN(callsW)}</td>\n          <td>${fmtN(mailsW)}</td>\n          <td class=\"group-qt ${statusColor(qualTotal, [30, 20])}\">${fmtN(qualTotal)}</td>\n          <td class=\"${statusColor(crPct, [20, 12])}\">${pct(crPct)}</td>\n          <td>${fmtN(r.qualCalls || 0)}</td>\n          <td>${fmtN(r.meetings || 0)}</td>\n          <td class=\"group-conv\">${fmtN(r.oppCreated || 0)}</td>\n          <td class=\"${statusColor(convPct, [20, 10])}\">${pct(convPct)}</td>\n          <td class=\"group-result ${pilotsColor}\">${pilots}</td>\n          <td>${fmt(bkARR)}</td>\n          <td class=\"${statusColor(r.coverageVal || 0, [2.5, 1.5])}\">${(r.coverageVal || 0).toFixed(1).replace('.',',')}x</td>\n          <td><span class=\"badge ${r.overallStatus || 'neutral'}\">${pct(ta)}</span></td>\n          <td><span class=\"risk-label ${diagCls}\">${diag.cause}</span></td>\n        </tr>`;\n    }).join('');\n\n    c.innerHTML = `\n      <table>\n        <thead>\n          <tr>\n            <th>Rep</th>\n            <th class=\"group-touch\">Touch/W</th>\n            <th>Calls/W</th>\n            <th>Mails/W</th>\n            <th class=\"group-qt\">QT</th>\n            <th>CR%</th>\n            <th>QC</th>\n            <th>Meetings</th>\n            <th class=\"group-conv\">Opps</th>\n            <th>Conv%</th>\n            <th class=\"group-result\">Pilots</th>\n            <th>Bookings</th>\n            <th>Cov</th>\n            <th class=\"center\">TA%</th>\n            <th>Risk</th>\n          </tr>\n        </thead>\n        <tbody>${rows}</tbody>\n      </table>`;\n  }\n\n  function extract(m) {\n    if (!m) return { reps: [], weeksElapsed: 1 };\n    return {\n      reps:         Array.isArray(m) ? m : (m.reps || []),\n      weeksElapsed: m.weeksElapsed || 1,\n    };\n  }\n\n  // Key: total bookingsTarget (quota) — 0 before Q_Quotas loads, non-zero after\n  function modelKey(m) {\n    return (m && m.reps || []).reduce(function(s,r){ return s+(r.bookingsTarget||0); }, 0);\n  }\n\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = modelKey(appsmith.model);\n      if (key !== _lastKey) { _lastKey = key; render(extract(appsmith.model)); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(extract(appsmith.model)); poll(); });\n    appsmith.onModelChange((m) => render(extract(m)));\n  } else {\n    render({ reps: [], weeksElapsed: 1 });\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
  "version": 1,
  "widgetId": "rep_table_widget1",
  "widgetName": "Rep_Table"
}