    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-row:     rgba(0,0,0,0.02);\n    --bg-hover:   rgba(0,0,0,0.04);\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --darkred:    #b02020;\n    --darkred-bg: rgba(176,32,32,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body { background: transparent; font-family: var(--font); color: var(--text-1); padding: 4px; }\n\n  .container {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    overflow: hidden;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n\n  .table-header {\n    display: grid;\n    grid-template-columns: 2fr 1.5fr 1fr 80px 70px;\n    gap: 8px;\n    padding: 8px 14px;\n    border-bottom: 1px solid var(--border);\n    background: rgba(0,0,0,0.03);\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n    color: var(--text-3);\n  }\n\n  .row {\n    display: grid;\n    grid-template-columns: 2fr 1.5fr 1fr 80px 70px;\n    gap: 8px;\n    padding: 9px 14px;\n    border-bottom: 1px solid var(--border);\n    align-items: center;\n    cursor: default;\n    transition: background .15s;\n  }\n  .row:last-child { border-bottom: none; }\n  .row:hover { background: var(--bg-hover); }\n\n  .opp-name  { font-size: 12px; font-weight: 700; color: var(--text-1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n  .opp-acc   { font-size: 10px; color: var(--text-3); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n  .rep-name  { font-size: 12px; color: var(--text-2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n  .stage     { font-size: 11px; color: var(--text-3); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n\n  .arr-val   { font-size: 12px; font-weight: 800; color: var(--text-2); text-align: right; }\n\n  .age-badge {\n    font-size: 10px;\n    font-weight: 800;\n    padding: 2px 8px;\n    border-radius: 20px;\n    white-space: nowrap;\n    text-align: center;\n  }\n  .age-badge.b1 { background: var(--amber-bg);   color: var(--amber);   }\n  .age-badge.b2 { background: var(--red-bg);      color: var(--red);     }\n  .age-badge.b3 { background: var(--darkred-bg);  color: var(--darkred); }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n</style>\n</head>\n<body>\n<div class=\"container\" id=\"container\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function fmt(n) {\n    if (!n) return '€\\u00a00';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return '€\\u00a0' + (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n    if (abs >= 1000)    return '€\\u00a0' + Math.round(abs/1000) + 'k';\n    return '€\\u00a0' + abs;\n  }\n\n  function ageBucket(days) {\n    if (days >= 30) return { cls: 'b3', label: '30d+' };\n    if (days >= 21) return { cls: 'b2', label: '21–30d' };\n    return                  { cls: 'b1', label: '14–21d' };\n  }\n\n  function render(list) {\n    const c = document.getElementById('container');\n    if (!Array.isArray(list) || list.length === 0) {\n      c.innerHTML = '<div class=\"empty\">Keine stale Opps</div>';\n      return;\n    }\n\n    const header = `\n      <div class=\"table-header\">\n        <span>Opportunity</span>\n        <span>Rep</span>\n        <span>Stage</span>\n        <span style=\"text-align:right\">ARR</span>\n        <span style=\"text-align:center\">Alter</span>\n      </div>`;\n\n    const rows = list.map(o => {\n      const bucket = ageBucket(o.daysSinceActivity || 0);\n      return `\n        <div class=\"row\">\n          <div>\n            <div class=\"opp-name\">${o.name || '—'}</div>\n            <div class=\"opp-acc\">${o.account || '—'}</div>\n          </div>\n          <div class=\"rep-name\">${o.rep || '—'}</div>\n          <div class=\"stage\">${o.stage || '—'}</div>\n          <div class=\"arr-val\">${fmt(o.arr)}</div>\n          <div style=\"text-align:center\"><span class=\"age-badge ${bucket.cls}\">${bucket.label}</span></div>\n        </div>`;\n    }).join('');\n\n    c.innerHTML = header + rows;\n  }\n\n  function extract(m) { return Array.isArray(m) ? m : (m && m.list) || []; }\n\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = JSON.stringify(extract(appsmith.model).length);\n      if (key !== _lastKey) { _lastKey = key; render(extract(appsmith.model)); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(extract(appsmith.model)); poll(); });\n    appsmith.onModelChange((m) => render(extract(m)));\n  } else {\n    render([]);\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
  "theme": "{{appsmith.theme}}",
