dth: 100%; border-collapse: collapse; font-size: 12px; }\n  .tbl th { padding: 7px 10px; border-bottom: 1px solid var(--border); background: var(--bg-header); font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); white-space: nowrap; user-select: none; }\n  .tbl th.sortable { cursor: pointer; }\n  .tbl th.sortable:hover { color: var(--text-2); }\n  .tbl th.sorted-asc::after  { content: ' \u2191'; color: var(--text-2); }\n  .tbl th.sorted-desc::after { content: ' \u2193'; color: var(--text-2); }\n  .tbl td { padding: 8px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; color: var(--text-2); }\n  .tbl tr:last-child td { border-bottom: none; }\n  .tbl tr:hover td { background: var(--bg-hover); }\n  .opp-link { font-weight: 700; color: var(--blue); text-decoration: none; }\n  .opp-link:hover { text-decoration: underline; }\n  .acc-link { color: var(--text-3); text-decoration: none; font-size: 11px; }\n  .acc-link:hover { color: var(--blue); text-decoration: underline; }\n  .arr-val { font-weight: 800; color: var(--text-2); white-space: nowrap; }\n  .age-badge { font-size: 10px; font-weight: 800; padding: 2px 8px; border-radius: 20px; white-space: nowrap; display: inline-block; }\n  .age-b1 { background: var(--amber-bg); color: var(--amber); }\n  .age-b2 { background: var(--red-bg); color: var(--red); }\n  .age-b3 { background: var(--darkred-bg); color: var(--darkred); }\n  .ovd-1 { color: var(--amber); font-weight: 800; }\n  .ovd-2 { color: var(--red); font-weight: 800; }\n  .ovd-3 { color: var(--darkred); font-weight: 800; }\n  .info-box { padding: 32px 20px; text-align: center; color: var(--text-3); font-size: 13px; line-height: 1.6; }\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n</style>\n</head>\n<body>\n<div class=\"container\" id=\"container\"><div class=\"empty\">Lade Daten\\u2026</div></div>\n<script>\n  var _sortKey = null, _sortDir = 'asc', _currentModel = null;\n\n  function fmtCurrency(n) {\n    if (!n) return '\\u20ac\\u00a00';\n    var abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) { return '\\u20ac\\u00a0' + (abs/1000000).toFixed(1).replace('.',',') + ' Mio.'; }\n    if (abs >= 1000) {\n      var s = String(abs), res = '';\n      while (s.length > 3) { res = '.' + s.slice(-3) + res; s = s.slice(0,-3); }\n      return '\\u20ac\\u00a0' + s + res;\n    }\n    return '\\u20ac\\u00a0' + abs;\n  }\n\n  function fmtDate(d) {\n    if (!d) return '\\u2014';\n    var dt = new Date(d);\n    if (isNaN(dt.getTime())) return d;\n    return ('0'+dt.getDate()).slice(-2)+'.'+('0'+(dt.getMonth()+1)).slice(-2)+'.'+dt.getFullYear();\n  }\n\n  function esc(s) {\n    if (s === null || s === undefined) return '\\u2014';\n    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  }\n\n  function ageBadge(days) {\n    var cls = days >= 30 ? 'age-b3' : days >= 21 ? 'age-b2' : 'age-b1';\n    var lbl = days >= 30 ? '30d+' : days >= 21 ? '21\\u201330d' : '14\\u201321d';\n    return '<span class=\"age-badge ' + cls + '\">' + lbl + '</span>';\n  }\n\n  function overdueHtml(days) {\n    var cls = days >= 60 ? 'ovd-3' : days >= 30 ? 'ovd-2' : 'ovd-1';\n    return '<span class=\"' + cls + '\">' + days + 'd</span>';\n  }\n\n  function renderCell(row, col) {\n    var val = row[col.key];\n    var alignAttr = col.align === 'right' ? ' style=\"text-align:right\"' : col.align === 'center' ? ' style=\"text-align:center\"' : '';\n    if (col.type === 'opp-link') {\n      var href = row.sfUrl;\n      return '<td>' + (href ? '<a class=\"opp-link\" href=\"'+esc(href)+'\" target=\"_blank\" rel=\"noopener\">'+esc(val)+'</a>' : esc(val)) + '</td>';\n    }\n    if (col.type === 'acc-link') {\n      if (!val || val === '\\u2014') return '<td><span style=\"color:var(--text-3)\">\\u2014</span></td>';\n      var accHref = row.sfAccUrl;\n      return '<td>' + (accHref ? '<a class=\"acc-link\" href=\"'+esc(accHref)+'\" target=\"_blank\" rel=\"noopener\">'+esc(val)+'</a>' : '<span style=\"font-size:11px;color:var(--text-3)\">'+esc(val)+'</span>') + '</td>';\n    }\n    if (col.type === 'currency') { return '<td'+alignAttr+'><span class=\"arr-val\">' + fmtCurrency(val) + '</span></td>'; }\n    if (col.type === 'date')     { return '<td>' + fmtDate(val) + '</td>'; }\n    if (col.type === 'age-badge'){ return '<td'+alignAttr+'>' + ageBadge(val||0) + '</td>'; }\n    if (col.type === 'overdue')  { return '<td'+alignAttr+'>' + overdueHtml(val||0) + '</td>'; }\n    if (val === null || val === undefined) return '<td>\\u2014</td>';\n    return '<td'+alignAttr+'>' + esc(String(val)) + '</td>';\n  }\n\n  function sortRows(rows, key, dir) {\n    return rows.slice().sort(function(a,b) {\n      var va = a[key], vb = b[key];\n      if (typeof va === 'number' && typeof vb === 'number') return dir === 'asc' ? va-vb : vb-va;\n      var sa = (va||'').toString().toLowerCase(), sb = (vb||'').toString().toLowerCase();\n      return dir === 'asc' ? (sa < sb ? -1 : sa > sb ? 1 : 0) : (sa > sb ? -1 : sa < sb ? 1 : 0);\n    });\n  }\n\n  function onSortClick(key) {\n    if (_sortKey === key) { _sortDir = _sortDir === 'asc' ? 'desc' : 'asc'; }\n    else { _sortKey = key; _sortDir = 'asc'; }\n    if (_currentModel) renderModel(_currentModel);\n  }\n\n  function onReset() {\n    if (typeof appsmith !== 'undefined') appsmith.triggerEvent('onResetDrilldown');\n  }\n\n  function renderModel(m) {\n    _currentModel = m;\n    var c = document.getElementById('container');\n    if (!m || typeof m !== 'object') { c.innerHTML = '<div class=\"empty\">Lade Daten\\u2026</div>'; return; }\n\n    var title    = m.title    || 'Stale Pipeline';\n    var columns  = Array.isArray(m.columns) ? m.columns : [];\n    var rows     = Array.isArray(m.rows)    ? m.rows    : [];\n    var infoMsg  = m.infoMessage || null;\n    var isDrill  = !!m.isDrilldown;\n\n    var resetBtn   = isDrill ? '<button class=\"reset-btn\" onclick=\"onReset()\">\\u2715 Stale Queue</button>' : '';\n    var countLabel = infoMsg  ? '' : '<span class=\"list-count\">'+rows.length+' Records</span>';\n    var headerHtml = '<div class=\"list-header\"><span class=\"list-title\">'+esc(title)+'</span>'+countLabel+resetBtn+'</div>';\n\n    if (infoMsg) { c.innerHTML = headerHtml + '<div class=\"info-box\">'+esc(infoMsg)+'</div>'; return; }\n    if (rows.length === 0) { c.innerHTML = headerHtml + '<div class=\"empty\">Keine Records gefunden</div>'; return; }\n\n    var sorted = _sortKey ? sortRows(rows, _sortKey, _sortDir) : rows;\n\n    var thHtml = columns.map(function(col) {\n      var alignAttr = col.align === 'right' ? ' style=\"text-align:right\"' : col.align === 'center' ? ' style=\"text-align:center\"' : '';\n      if (!col.sortable) return '<th'+alignAttr+'>'+esc(col.label)+'</th>';\n      var cls = 'sortable' + (_sortKey === col.key ? ' sorted-'+_sortDir : '');\n      return '<th class=\"'+cls+'\"'+alignAttr+' onclick=\"onSortClick(\\''+col.key+'\\')\">'+esc(col.label)+'</th>';\n    }).join('');\n\n    var trHtml = sorted.map(function(row) {\n      return '<tr>' + columns.map(function(col) { return renderCell(row, col); }).join('') + '</tr>';\n    }).join('');\n\n    c.innerHTML = headerHtml + '<div class=\"table-wrap\"><table class=\"tbl\"><thead><tr>'+thHtml+'</tr></thead><tbody>'+trHtml+'</tbody></table></div>';\n  }\n\n  var _lastSig = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var m = appsmith.model;\n      var sig = JSON.stringify({ t: m.title, l: (m.rows||[]).length, d: m.isDrilldown });\n      if (sig !== _lastSig) { _lastSig = sig; _sortKey = null; _sortDir = 'asc'; renderModel(m); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(function() { renderModel(appsmith.model); poll(); });\n    appsmith.onModelChange(function(m) { _sortKey = null; _sortDir = 'asc'; renderModel(m); });\n  } else { renderModel(null); }\n</script>\n</body>\n</html>",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
