    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n\t<head>\n\t\t<meta charset=\"UTF-8\">\n\t\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t\t<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\t\t<style>\n\t\t\t* { box-sizing: border-box; margin: 0; padding: 0; }\n\n\t\t\t:root {\n\t\t\t\t--bg-card:    #222244;\n\t\t\t\t--bg-hover:   #2a2a50;\n\t\t\t\t--bg-surface: #16162b;\n\t\t\t\t--text-1:     #f0f0f5;\n\t\t\t\t--text-2:     #a0a0bb;\n\t\t\t\t--text-3:     #6e6e88;\n\t\t\t\t--green:      #58cc02;\n\t\t\t\t--green-bg:   rgba(88,204,2,0.12);\n\t\t\t\t--amber:      #ff9600;\n\t\t\t\t--amber-bg:   rgba(255,150,0,0.12);\n\t\t\t\t--red:        #ff4b4b;\n\t\t\t\t--red-bg:     rgba(255,75,75,0.12);\n\t\t\t\t--blue:       #1cb0f6;\n\t\t\t\t--blue-bg:    rgba(28,176,246,0.12);\n\t\t\t\t--border:     rgba(255,255,255,0.08);\n\t\t\t\t--radius:     14px;\n\t\t\t\t--font:       'Nunito', system-ui, sans-serif;\n\t\t\t}\n\n\t\t\tbody {\n\t\t\t\tbackground: transparent;\n\t\t\t\tfont-family: var(--font);\n\t\t\t\tcolor: var(--text-1);\n\t\t\t\tpadding: 4px;\n\t\t\t}\n\n\t\t\t.grid {\n\t\t\t\tdisplay: grid;\n\t\t\t\tgrid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n\t\t\t\tgap: 10px;\n\t\t\t}\n\n\t\t\t.card {\n\t\t\t\tbackground: var(--bg-card);\n\t\t\t\tborder: 1px solid var(--border);\n\t\t\t\tborder-radius: var(--radius);\n\t\t\t\tpadding: 14px 16px;\n\t\t\t\tdisplay: flex;\n\t\t\t\tflex-direction: column;\n\t\t\t\tgap: 10px;\n\t\t\t\tcursor: default;\n\t\t\t\ttransition: background .2s, border-color .2s;\n\t\t\t\tborder-left-width: 3px;\n\t\t\t}\n\t\t\t.card:hover { background: var(--bg-hover); }\n\t\t\t.card.red    { border-left-color: var(--red);    }\n\t\t\t.card.amber  { border-left-color: var(--amber);  }\n\t\t\t.card.green  { border-left-color: var(--green);  }\n\t\t\t.card.neutral{ border-left-color: var(--border); }\n\n\t\t\t/* ── Header ── */\n\t\t\t.card-header {\n\t\t\t\tdisplay: flex;\n\t\t\t\talign-items: flex-start;\n\t\t\t\tjustify-content: space-between;\n\t\t\t\tgap: 8px;\n\t\t\t}\n\t\t\t.rep-name {\n\t\t\t\tfont-size: 13px;\n\t\t\t\tfont-weight: 800;\n\t\t\t\tcolor: var(--text-1);\n\t\t\t\tline-height: 1.2;\n\t\t\t}\n\t\t\t.rep-meta {\n\t\t\t\tdisplay: flex;\n\t\t\t\tgap: 5px;\n\t\t\t\tmargin-top: 4px;\n\t\t\t\tflex-wrap: wrap;\n\t\t\t}\n\t\t\t.tag {\n\t\t\t\tfont-size: 10px;\n\t\t\t\tfont-weight: 700;\n\t\t\t\tpadding: 2px 7px;\n\t\t\t\tborder-radius: 20px;\n\t\t\t\tbackground: rgba(255,255,255,0.07);\n\t\t\t\tcolor: var(--text-3);\n\t\t\t\tletter-spacing: .04em;\n\t\t\t\twhite-space: nowrap;\n\t\t\t}\n\t\t\t.tag.team-ferdinand { background: rgba(28,176,246,0.15); color: var(--blue); }\n\t\t\t.tag.team-jan       { background: rgba(255,150,0,0.15);  color: var(--amber); }\n\t\t\t.tag.team-philipp   { background: rgba(88,204,2,0.15);   color: var(--green); }\n\n\t\t\t/* ── Composite score ── */\n\t\t\t.score-row {\n\t\t\t\tdisplay: flex;\n\t\t\t\talign-items: center;\n\t\t\t\tgap: 10px;\n\t\t\t}\n\t\t\t.score-val {\n\t\t\t\tfont-size: 36px;\n\t\t\t\tfont-weight: 900;\n\t\t\t\tline-height: 1;\n\t\t\t\tmin-width: 64px;\n\t\t\t}\n\t\t\t.score-val.red    { color: var(--red);   }\n\t\t\t.score-val.amber  { color: var(--amber); }\n\t\t\t.score-val.green  { color: var(--green); }\n\t\t\t.score-val.neutral{ color: var(--text-3); }\n\n\t\t\t.score-detail {\n\t\t\t\tdisplay: flex;\n\t\t\t\tflex-direction: column;\n\t\t\t\tgap: 3px;\n\t\t\t\tflex: 1;\n\t\t\t}\n\t\t\t.score-sub {\n\t\t\t\tfont-size: 11px;\n\t\t\t\tcolor: var(--text-3);\n\t\t\t\tdisplay: flex;\n\t\t\t\tjustify-content: space-between;\n\t\t\t}\n\t\t\t.score-sub span:last-child { color: var(--text-2); font-weight: 700; }\n\n\t\t\t.progress-track {\n\t\t\t\theight: 5px;\n\t\t\t\tbackground: rgba(255,255,255,0.08);\n\t\t\t\tborder-radius: 99px;\n\t\t\t\toverflow: hidden;\n\t\t\t}\n\t\t\t.progress-fill {\n\t\t\t\theight: 100%;\n\t\t\t\tborder-radius: 99px;\n\t\t\t\ttransition: width .4s ease;\n\t\t\t}\n\t\t\t.progress-fill.red    { background: var(--red);   }\n\t\t\t.progress-fill.amber  { background: var(--amber); }\n\t\t\t.progress-fill.green  { background: var(--green); }\n\t\t\t.progress-fill.neutral{ background: var(--text-3); }\n\n\t\t\t/* ── KPI grid ── */\n\t\t\t.divider { height: 1px; background: var(--border); }\n\n\t\t\t.kpi-grid {\n\t\t\t\tdisplay: grid;\n\t\t\t\tgrid-template-columns: 1fr 1fr;\n\t\t\t\tgap: 6px 12px;\n\t\t\t}\n\t\t\t.kpi-cell {\n\t\t\t\tdisplay: flex;\n\t\t\t\tflex-direction: column;\n\t\t\t\tgap: 2px;\n\t\t\t}\n\t\t\t.kpi-label { font-size: 10px; color: var(--text-3); font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }\n\t\t\t.kpi-value { font-size: 15px; font-weight: 800; }\n\t\t\t.kpi-value.red    { color: var(--red);   }\n\t\t\t.kpi-value.amber  { color: var(--amber); }\n\t\t\t.kpi-value.green  { color: var(--green); }\n\t\t\t.kpi-value.neutral{ color: var(--text-2); }\n\n\t\t\t/* ── Activity row ── */\n\t\t\t.activity-row {\n\t\t\t\tdisplay: flex;\n\t\t\t\tjustify-content: space-between;\n\t\t\t\tgap: 6px;\n\t\t\t}\n\t\t\t.act-cell {\n\t\t\t\tflex: 1;\n\t\t\t\tbackground: rgba(255,255,255,0.04);\n\t\t\t\tborder-radius: 8px;\n\t\t\t\tpadding: 5px 4px;\n\t\t\t\ttext-align: center;\n\t\t\t}\n\t\t\t.act-val   { font-size: 14px; font-weight: 800; color: var(--text-2); }\n\t\t\t.act-label { font-size: 9px;  color: var(--text-3); margin-top: 1px; text-transform: uppercase; letter-spacing: .04em; }\n\n\t\t\t/* ── Diagnosis tag ── */\n\t\t\t.diagnosis {\n\t\t\t\tdisplay: flex;\n\t\t\t\talign-items: center;\n\t\t\t\tgap: 6px;\n\t\t\t\tfont-size: 11px;\n\t\t\t\tfont-weight: 700;\n\t\t\t\tpadding: 5px 10px;\n\t\t\t\tborder-radius: 8px;\n\t\t\t\tbackground: rgba(255,255,255,0.04);\n\t\t\t\tcolor: var(--text-3);\n\t\t\t}\n\t\t\t.diagnosis.sev-3 { background: var(--red-bg);   color: var(--red);   }\n\t\t\t.diagnosis.sev-2 { background: var(--amber-bg); color: var(--amber); }\n\t\t\t.diagnosis.sev-1 { background: rgba(255,150,0,0.08); color: var(--text-2); }\n\t\t\t.diagnosis::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }\n\n\t\t\t.empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n\t\t</style>\n\t</head>\n\t<body>\n\n\t\t<div class=\"grid\" id=\"grid\">\n\t\t\t<div class=\"empty\">Lade Daten…</div>\n\t\t</div>\n\n\t\t<script>\n\t\t\tfunction pct(n)  { return (n || 0) + '\\u202f%'; }\n\t\t\tfunction fmt(n)  {\n\t\t\t\tif (!n) return '€\\u00a00';\n\t\t\t\tconst abs = Math.round(Math.abs(n));\n\t\t\t\tif (abs >= 1000000) return '€\\u00a0' + (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n\t\t\t\tif (abs >= 1000)    return '€\\u00a0' + Math.round(abs/1000) + 'k';\n\t\t\t\treturn '€\\u00a0' + abs;\n\t\t\t}\n\t\t\tfunction fmtN(n) { return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.'); }\n\t\t\tfunction clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n\t\t\tfunction teamClass(team) {\n\t\t\t\treturn { ferdinand: 'team-ferdinand', jan: 'team-jan', philipp: 'team-philipp' }[team] || '';\n\t\t\t}\n\t\t\tfunction teamLabel(team) {\n\t\t\t\treturn { ferdinand: 'Ferdinand', jan: 'Jan', philipp: 'Philipp' }[team] || (team || '—');\n\t\t\t}\n\t\t\tfunction levelLabel(level) {\n\t\t\t\treturn { '3': 'L3', '2': 'L2', '1': 'L1', 'rampup': 'Ramp-up' }[level] || 'L2';\n\t\t\t}\n\n\t\t\tfunction renderCard(rep) {\n\t\t\t\tconst status      = rep.overallStatus || 'neutral';\n\t\t\t\tconst composite   = rep.composite != null ? rep.composite : null;\n\t\t\t\tconst compLabel   = composite != null ? pct(composite) : '—';\n\t\t\t\tconst bAtt        = rep.bookingsAtt || 0;\n\t\t\t\tconst pAtt        = rep.pilotenAtt  || 0;\n\t\t\t\tconst bW          = rep.bookingsWeight != null ? rep.bookingsWeight : 0.5;\n\t\t\t\tconst pW          = rep.pilotenWeight  != null ? rep.pilotenWeight  : 0.5;\n\n\t\t\t\tconst cov     = (rep.coverageVal || 0).toFixed(1).replace('.',',') + 'x';\n\t\t\t\tconst covSt   = rep.coverageStatus  || 'neutral';\n\t\t\t\tconst wr      = pct(rep.winRateVal  || 0);\n\t\t\t\tconst wrSt    = rep.winRateStatus   || 'neutral';\n\t\t\t\tconst stale   = pct(rep.staleRateVal || 0);\n\t\t\t\tconst staleSt = rep.staleRateStatus || 'neutral';\n\n\t\t\t\tconst diag    = rep.rootCause || { cause: '—', severity: 0 };\n\t\t\t\tconst diagCls = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : '';\n\n\t\t\t\tconst bFill = clamp(bAtt, 0, 100);\n\t\t\t\tconst pFill = clamp(pAtt, 0, 100);\n\n\t\t\t\treturn `\n      <div class=\"card ${status}\">\n        <div class=\"card-header\">\n          <div>\n            <div class=\"rep-name\">${rep.repName || '—'}</div>\n            <div class=\"rep-meta\">\n              <span class=\"tag\">${levelLabel(rep.level)}</span>\n              <span class=\"tag ${teamClass(rep.team)}\">${teamLabel(rep.team)}</span>\n\t\t\t</div>\n\t\t\t</div>\n\t\t\t</div>\n\n        <div class=\"score-row\">\n          <div class=\"score-val ${status}\">${compLabel}</div>\n          <div class=\"score-detail\">\n            <div class=\"score-sub\">\n              <span>Bookings (${Math.round((bW||0.5)*100)}%)</span>\n              <span>${pct(bAtt)}</span>\n\t\t\t</div>\n            <div class=\"progress-track\">\n              <div class=\"progress-fill ${bAtt >= 80 ? 'green' : bAtt >= 60 ? 'amber' : 'red'}\" style=\"width:${bFill}%\"></div>\n\t\t\t</div>\n            ${pW > 0 ? `\n            <div class=\"score-sub\" style=\"margin-top:4px\">\n              <span>Piloten (${Math.round((pW||0.5)*100)}%)</span>\n              <span>${pct(pAtt)}</span>\n\t\t\t</div>\n            <div class=\"progress-track\">\n              <div class=\"progress-fill ${pAtt >= 80 ? 'green' : pAtt >= 60 ? 'amber' : 'red'}\" style=\"width:${pFill}%\"></div>\n\t\t\t</div>` : ''}\n\t\t\t</div>\n\t\t\t</div>\n\n        <div class=\"divider\"></div>\n\n        <div class=\"kpi-grid\">\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Coverage</span>\n            <span class=\"kpi-value ${covSt}\">${cov}</span>\n\t\t\t</div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Win Rate</span>\n            <span class=\"kpi-value ${wrSt}\">${wr}</span>\n\t\t\t</div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Stale</span>\n            <span class=\"kpi-value ${staleSt}\">${stale}</span>\n\t\t\t</div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Forecast</span>\n            <span class=\"kpi-value neutral\">${fmt(rep.forecast)}</span>\n\t\t\t</div>\n\t\t\t</div>\n\n        <div class=\"activity-row\">\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.dials || 0)}</div><div class=\"act-label\">Anwahlen</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.qualCalls || 0)}</div><div class=\"act-label\">Qual. Calls</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.meetings || 0)}</div><div class=\"act-label\">Meetings</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.emails || 0)}</div><div class=\"act-label\">E-Mails</div></div>\n\t\t\t</div>\n\n        <div class=\"diagnosis ${diagCls}\">${diag.cause}</div>\n\t\t\t</div>`;\n\t\t\t}\n\n\t\t\tfunction render(reps) {\n\t\t\t\tconst grid = document.getElementById('grid');\n\t\t\t\tif (!Array.isArray(reps) || reps.length === 0) {\n\t\t\t\t\tgrid.innerHTML = '<div class=\"empty\">Keine Daten</div>';\n\t\t\t\t\treturn;\n\t\t\t\t}\n\t\t\t\tgrid.innerHTML = reps.map(renderCard).join('');\n\t\t\t}\n\n\t\t\tfunction extract(m) { return Array.isArray(m) ? m : (m && m.reps) || []; }\n\n\t\t\tif (typeof appsmith !== 'undefined') {\n\t\t\t\tappsmith.onReady(() => render(extract(appsmith.model)));\n\t\t\t\tappsmith.onModelChange((m) => render(extract(m)));\n\t\t\t} else {\n\t\t\t\trender([]);\n\t\t\t}\n\t\t</script>\n\t</body>\n</html>",
    "js": "function _extends() { return _extends = Object.assign ? Object.assign.bind() : function (n) { for (var e = 1; e < arguments.length; e++) { var t = arguments[e]; for (var r in t) ({}).hasOwnProperty.call(t, r) && (n[r] = t[r]); } return n; }, _extends.apply(null, arguments); }\nimport React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\nconst Button = ({\n  children,\n  className,\n  ...props\n}) => /*#__PURE__*/React.createElement(\"button\", _extends({\n  className: className\n}, props), children);\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n  const handleNext = () => {\n    setCurrentIndex(prevIndex => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n  return /*#__PURE__*/React.createElement(\"div\", {\n    className: \"app\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-container\"\n  }, /*#__PURE__*/React.createElement(\"div\", {\n    className: \"tip-header\"\n  }, /*#__PURE__*/React.createElement(\"h2\", null, \"Custom Widget\"), /*#__PURE__*/React.createElement(\"div\", null, currentIndex + 1, \" / \", appsmith.model.tips.length)), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"content\"\n  }, appsmith.model.tips[currentIndex])), /*#__PURE__*/React.createElement(\"div\", {\n    className: \"button-container\"\n  }, /*#__PURE__*/React.createElement(Button, {\n    className: \"primary\",\n    onClick: handleNext\n  }, \"Next Tip\"), /*#__PURE__*/React.createElement(Button, {\n    className: \"reset\",\n    disabled: currentIndex === 0,\n    onClick: handleReset\n  }, \"Reset\")));\n}\nappsmith.onReady(() => {\n  /*\n  \t * This handler function will get called when parent application is ready.\n  \t * Initialize your component here\n  \t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n  \t */\n  ReactDOM.render(/*#__PURE__*/React.createElement(App, null), document.getElementById(\"root\"));\n});"
