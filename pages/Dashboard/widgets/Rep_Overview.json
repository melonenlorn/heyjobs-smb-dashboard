    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --bg-card:    #ffffff;\n    --bg-hover:   #f4f4ff;\n    --bg-surface: #f0f2ff;\n    --text-1:     #1a1a2e;\n    --text-2:     #4a4a6a;\n    --text-3:     #9090b0;\n    --green:      #2e9e00;\n    --green-bg:   rgba(46,158,0,0.10);\n    --amber:      #c97800;\n    --amber-bg:   rgba(201,120,0,0.10);\n    --red:        #d93232;\n    --red-bg:     rgba(217,50,50,0.10);\n    --blue:       #0078d4;\n    --blue-bg:    rgba(0,120,212,0.10);\n    --border:     rgba(0,0,0,0.08);\n    --radius:     14px;\n    --font:       'Nunito', system-ui, sans-serif;\n  }\n\n  body {\n    background: transparent;\n    font-family: var(--font);\n    color: var(--text-1);\n    padding: 4px;\n  }\n\n  .grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 10px;\n  }\n\n  .card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: var(--radius);\n    padding: 14px 16px;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    cursor: default;\n    transition: background .2s, border-color .2s;\n    border-left-width: 3px;\n    box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n  }\n  .card:hover { background: var(--bg-hover); }\n  .card.red    { border-left-color: var(--red);    }\n  .card.amber  { border-left-color: var(--amber);  }\n  .card.green  { border-left-color: var(--green);  }\n  .card.neutral{ border-left-color: var(--border); }\n\n  /* ── Header ── */\n  .card-header {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 8px;\n  }\n  .rep-name {\n    font-size: 13px;\n    font-weight: 800;\n    color: var(--text-1);\n    line-height: 1.2;\n  }\n  .rep-meta {\n    display: flex;\n    gap: 5px;\n    margin-top: 4px;\n    flex-wrap: wrap;\n  }\n  .tag {\n    font-size: 10px;\n    font-weight: 700;\n    padding: 2px 7px;\n    border-radius: 20px;\n    background: rgba(0,0,0,0.05);\n    color: var(--text-3);\n    letter-spacing: .04em;\n    white-space: nowrap;\n  }\n  .tag.team-ferdinand { background: rgba(0,120,212,0.10); color: var(--blue); }\n  .tag.team-jan       { background: rgba(201,120,0,0.10); color: var(--amber); }\n  .tag.team-philipp   { background: rgba(46,158,0,0.10);  color: var(--green); }\n\n  /* ── Composite score ── */\n  .score-row {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .score-val {\n    font-size: 36px;\n    font-weight: 900;\n    line-height: 1;\n    min-width: 64px;\n  }\n  .score-val.red    { color: var(--red);   }\n  .score-val.amber  { color: var(--amber); }\n  .score-val.green  { color: var(--green); }\n  .score-val.neutral{ color: var(--text-3); }\n\n  .score-detail {\n    display: flex;\n    flex-direction: column;\n    gap: 3px;\n    flex: 1;\n  }\n  .score-sub {\n    font-size: 11px;\n    color: var(--text-3);\n    display: flex;\n    justify-content: space-between;\n  }\n  .score-sub span:last-child { color: var(--text-2); font-weight: 700; }\n\n  .progress-track {\n    height: 5px;\n    background: rgba(0,0,0,0.07);\n    border-radius: 99px;\n    overflow: hidden;\n  }\n  .progress-fill {\n    height: 100%;\n    border-radius: 99px;\n    transition: width .4s ease;\n  }\n  .progress-fill.red    { background: var(--red);   }\n  .progress-fill.amber  { background: var(--amber); }\n  .progress-fill.green  { background: var(--green); }\n  .progress-fill.neutral{ background: var(--text-3); }\n\n  /* ── KPI grid ── */\n  .divider { height: 1px; background: var(--border); }\n\n  .kpi-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 6px 12px;\n  }\n  .kpi-cell {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n  .kpi-label { font-size: 10px; color: var(--text-3); font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }\n  .kpi-value { font-size: 15px; font-weight: 800; }\n  .kpi-value.red    { color: var(--red);   }\n  .kpi-value.amber  { color: var(--amber); }\n  .kpi-value.green  { color: var(--green); }\n  .kpi-value.neutral{ color: var(--text-2); }\n\n  /* ── Activity row ── */\n  .activity-row {\n    display: flex;\n    justify-content: space-between;\n    gap: 6px;\n  }\n  .act-cell {\n    flex: 1;\n    background: rgba(0,0,0,0.04);\n    border-radius: 8px;\n    padding: 5px 4px;\n    text-align: center;\n  }\n  .act-val   { font-size: 14px; font-weight: 800; color: var(--text-2); }\n  .act-label { font-size: 9px;  color: var(--text-3); margin-top: 1px; text-transform: uppercase; letter-spacing: .04em; }\n\n  /* ── Diagnosis tag ── */\n  .diagnosis {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 11px;\n    font-weight: 700;\n    padding: 5px 10px;\n    border-radius: 8px;\n    background: rgba(0,0,0,0.04);\n    color: var(--text-3);\n  }\n  .diagnosis.sev-3 { background: var(--red-bg);   color: var(--red);   }\n  .diagnosis.sev-2 { background: var(--amber-bg); color: var(--amber); }\n  .diagnosis.sev-1 { background: rgba(201,120,0,0.06); color: var(--text-2); }\n  .diagnosis::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }\n\n  .empty { color: var(--text-3); font-size: 13px; text-align: center; padding: 40px; }\n</style>\n</head>\n<body>\n\n<div class=\"grid\" id=\"grid\">\n  <div class=\"empty\">Lade Daten…</div>\n</div>\n\n<script>\n  function pct(n)  { return (n || 0) + '\\u202f%'; }\n  function col(s) {\n    return { green: 'var(--green)', amber: 'var(--amber)', red: 'var(--red)' }[s] || 'var(--text-2)';\n  }\n  function fmt(n)  {\n    if (!n) return '€\\u00a00';\n    const abs = Math.round(Math.abs(n));\n    if (abs >= 1000000) return '€\\u00a0' + (abs/1000000).toFixed(1).replace('.',',') + ' Mio.';\n    if (abs >= 1000)    return '€\\u00a0' + Math.round(abs/1000) + 'k';\n    return '€\\u00a0' + abs;\n  }\n  function fmtN(n) { return (n || 0).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, '.'); }\n  function clamp(v, mn, mx) { return Math.max(mn, Math.min(mx, v)); }\n\n  function teamClass(team) {\n    return { ferdinand: 'team-ferdinand', jan: 'team-jan', philipp: 'team-philipp' }[team] || '';\n  }\n  function teamLabel(team) {\n    return { ferdinand: 'Wolves', jan: 'Titans', philipp: 'Locos' }[team] || (team || '—');\n  }\n  function levelLabel(level) {\n    return { '3': 'L3', '2': 'L2', '1': 'L1', 'rampup': 'Ramp-up' }[level] || 'L2';\n  }\n\n  function renderCard(rep) {\n    const status      = rep.overallStatus || 'neutral';\n    const composite   = rep.composite != null ? rep.composite : null;\n    const compLabel   = composite != null ? pct(composite) : '—';\n    const bAtt        = rep.bookingsAtt || 0;\n    const pAtt        = rep.pilotenAtt  || 0;\n    const bW          = rep.bookingsWeight != null ? rep.bookingsWeight : 0.5;\n    const pW          = rep.pilotenWeight  != null ? rep.pilotenWeight  : 0.5;\n\n    const cov     = (rep.coverageVal || 0).toFixed(1).replace('.',',') + 'x';\n    const covSt   = rep.coverageStatus  || 'neutral';\n    const wr      = pct(rep.winRateVal  || 0);\n    const wrSt    = rep.winRateStatus   || 'neutral';\n    const stale   = pct(rep.staleRateVal || 0);\n    const staleSt = rep.staleRateStatus || 'neutral';\n\n    const diag    = rep.rootCause || { cause: '—', severity: 0 };\n    const diagCls = diag.severity >= 3 ? 'sev-3' : diag.severity >= 2 ? 'sev-2' : diag.severity >= 1 ? 'sev-1' : '';\n\n    const bFill = clamp(bAtt, 0, 100);\n    const pFill = clamp(pAtt, 0, 100);\n    const bSt   = bAtt >= 80 ? 'green' : bAtt >= 60 ? 'amber' : 'red';\n    const pSt   = pAtt >= 80 ? 'green' : pAtt >= 60 ? 'amber' : 'red';\n    const compFore     = rep.compositeForecast   || 0;\n    const badgeCls     = compFore >= 100 ? 'green' : (compFore >= 80 ? 'amber' : 'red');\n    const bForeAtt     = rep.forecastAtt         || 0;\n    const pilotenCnt   = rep.pilotenCount        || 0;\n    const pilotenTgt   = rep.pilotenTarget       || 0;\n    const pilotenForeN = rep.pilotenForecast     || 0;\n    const pilotenForeA = rep.pilotenForecastAtt  || 0;\n\n    return `\n      <div class=\"card ${status}\">\n        <div class=\"card-header\">\n          <div>\n            <div class=\"rep-name\">${rep.repName || '—'}</div>\n            <div class=\"rep-meta\">\n              <span class=\"tag\">${levelLabel(rep.level)}</span>\n              <span class=\"tag ${teamClass(rep.team)}\">${teamLabel(rep.team)}</span>\n            </div>\n          </div>\n        </div>\n\n        <!-- composite header -->\n        <div style=\"display:flex;justify-content:space-between;align-items:flex-start\">\n          <div>\n            <div class=\"score-val ${status}\">${compLabel}</div>\n            <div style=\"font-size:9px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;margin-top:2px\">Composite</div>\n          </div>\n          <span class=\"badge ${badgeCls}\" style=\"margin-top:4px\">Hochr. ${pct(compFore)}</span>\n        </div>\n\n        <!-- bookings block -->\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:8px;padding:7px 9px;display:flex;flex-direction:column;gap:4px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Bookings · ${Math.round((bW||0.75)*100)} %</span>\n            <span style=\"font-size:11px;font-weight:900;color:${col(bSt)}\">TA ${pct(bAtt)}</span>\n          </div>\n          <div style=\"height:4px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n            <div style=\"height:100%;border-radius:99px;width:${clamp(bAtt,0,100)}%;background:${col(bSt)}\"></div>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:10px;color:var(--text-3)\">\n            <span>${fmt(rep.bookingsARR)} <span style=\"opacity:.6\">/ ${fmt(rep.bookingsTarget)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${pct(bForeAtt)}</span>\n          </div>\n        </div>\n\n        <!-- piloten block (hidden for rampup) -->\n        ${pW > 0 ? `\n        <div style=\"background:rgba(0,0,0,0.035);border-radius:8px;padding:7px 9px;display:flex;flex-direction:column;gap:4px\">\n          <div style=\"display:flex;justify-content:space-between;align-items:center\">\n            <span style=\"font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)\">Piloten · ${Math.round((pW||0.25)*100)} %</span>\n            <span style=\"font-size:11px;font-weight:900;color:${col(pSt)}\">TA ${pct(pAtt)}</span>\n          </div>\n          <div style=\"height:4px;background:rgba(0,0,0,0.08);border-radius:99px;overflow:hidden\">\n            <div style=\"height:100%;border-radius:99px;width:${clamp(pAtt,0,100)}%;background:${col(pSt)}\"></div>\n          </div>\n          <div style=\"display:flex;justify-content:space-between;font-size:10px;color:var(--text-3)\">\n            <span>${fmtN(pilotenCnt)} <span style=\"opacity:.6\">/ ${fmtN(pilotenTgt)}</span></span>\n            <span style=\"font-weight:700;color:var(--text-2)\">H: ${fmtN(pilotenForeN)} (${pct(pilotenForeA)})</span>\n          </div>\n        </div>` : ''}\n\n        <div class=\"divider\"></div>\n\n        <div class=\"kpi-grid\">\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Coverage</span>\n            <span class=\"kpi-value ${covSt}\">${cov}</span>\n          </div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Win Rate</span>\n            <span class=\"kpi-value ${wrSt}\">${wr}</span>\n          </div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Stale</span>\n            <span class=\"kpi-value ${staleSt}\">${stale}</span>\n          </div>\n          <div class=\"kpi-cell\">\n            <span class=\"kpi-label\">Forecast</span>\n            <span class=\"kpi-value neutral\">${fmt(rep.forecast)}</span>\n          </div>\n        </div>\n\n        <div class=\"activity-row\">\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.dials || 0)}</div><div class=\"act-label\">Anwahlen</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.qualCalls || 0)}</div><div class=\"act-label\">Qual. Calls</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.meetings || 0)}</div><div class=\"act-label\">Meetings</div></div>\n          <div class=\"act-cell\"><div class=\"act-val\">${fmtN(rep.emails || 0)}</div><div class=\"act-label\">E-Mails</div></div>\n        </div>\n\n        <div class=\"diagnosis ${diagCls}\">${diag.cause}</div>\n      </div>`;\n  }\n\n  function render(reps) {\n    const grid = document.getElementById('grid');\n    if (!Array.isArray(reps) || reps.length === 0) {\n      grid.innerHTML = '<div class=\"empty\">Keine Risiko-Reps</div>';\n      return;\n    }\n    grid.innerHTML = reps.map(renderCard).join('');\n  }\n\n  // Top-3 worst reps: prefer red, fall back to worst 3 overall\n  function extract(m) {\n    const arr = Array.isArray(m) ? m : (m && m.reps) || [];\n    const red = arr.filter(r => r.overallStatus === 'red');\n    return (red.length >= 3 ? red : arr).slice(0, 3);\n  }\n\n  // Key: total bookingsTarget (quota) — 0 before Q_Quotas loads, non-zero after\n  function modelKey(m) {\n    return (m && m.reps || []).reduce(function(s,r){ return s+(r.bookingsTarget||0); }, 0);\n  }\n\n  var _lastKey = null;\n  function poll() {\n    if (typeof appsmith !== 'undefined' && appsmith.model) {\n      var key = modelKey(appsmith.model);\n      if (key !== _lastKey) { _lastKey = key; render(extract(appsmith.model)); }\n    }\n    setTimeout(poll, 300);\n  }\n\n  if (typeof appsmith !== 'undefined') {\n    appsmith.onReady(() => { render(extract(appsmith.model)); poll(); });\n    appsmith.onModelChange((m) => render(extract(m)));\n  } else {\n    render([]);\n  }\n</script>\n</body>\n</html>\n",
    "js": "appsmith.onReady(() => { if (typeof poll === 'function') { poll(); } });"
  },
  "version": 1,
  "widgetId": "lbbbiq27xm",
  "widgetName": "Rep_Overview"
}